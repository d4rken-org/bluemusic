    <string name="devices_device_config_monitoring_duration_label">Monitoraggio della durata</string>
    <string name="devices_device_config_monitoring_duration_desc">Un timer in ms, dopo che le necessarie regolazioni sono state effettuate, nel corso del quale qualsiasi ulteriore cambiamento del volume sarà bloccato.</string>
    <string name="devices_device_config_adjustment_delay_label">Regolazione ritardo</string>
    <string name="devices_device_config_adjustment_delay_desc">Il ritardo in millisecondi fra la regolazione di ogni volume. Un ritardo di 0 millisecondi significa che il volume viene impostato non appena questo dispositivo viene connesso.</string>
    <string name="devices_device_config_reaction_delay_label">Ritardo reazione</string>
    <string name="devices_device_config_reaction_delay_desc">Il ritardo in millisecondi prima che quest\'app reagisca con questo dispositivo.</string>
    <string name="devices_device_config_section_reaction_label">Reazione</string>
    <string name="devices_device_config_launch_app_label">Avvio app</string>
    <string name="devices_device_config_launch_app_desc">Avvia un\'app quando questo dispositivo viene connesso.</string>
    <string name="devices_device_config_launch_app_multiple_desc">%d app selezionate</string>
    <string name="devices_device_config_show_home_screen_label">Mostra schermata home</string>
    <string name="devices_device_config_show_home_screen_desc">Dopo che tutti gli eventi per questo dispositivo sono elaborati, prova a mostrare la schermata home. Potrebbe non funzionare su tutte le versioni di Android.</string>
    <string name="devices_device_config_nudge_volume_label">Regola volume</string>
    <string name="devices_device_config_nudge_volume_description">Abbassa e poi alza il volume di un incremento, anche se il volume desiderato è già impostato (secondo il sistema).</string>
    <string name="devices_device_config_visible_adjustments_label">Regolazioni visibili</string>
    <string name="devices_device_config_visible_adjustments_desc">Mostra la finestra del volume del sistema mentre questa app effettua regolazioni per questo dispositivo.</string>
    <string name="devices_device_config_keep_awake_label">Mantieni attivo</string>
    <string name="devices_device_config_keep_awake_desc">Prova a mantenere il dispositivo attivo mentre è connesso. Il comportamento può variare a seconda della versione di Android.</string>
    <string name="devices_device_config_volume_observe_label">Osserva cambiamenti</string>
    <string name="devices_device_config_volume_observe_desc">Resta attivo mentre questo dispositivo è connesso e salva i cambiamenti di volume non causati da questa app.</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">Salva volume alla disconnessione</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">Cattura e salva i livelli di volume attuali quando questo dispositivo si disconnette.</string>
    <string name="devices_device_config_volume_save_on_disconnect_hint">Su alcuni dispositivi, il sistema cambia il routing audio prima che possiamo leggere i volumi. Se i valori salvati non corrispondono a quelli impostati, prova ad abilitare \"Osserva modifiche volume\" invece.</string>
    <string name="devices_device_config_volume_lock_label">Blocco volume</string>
    <string name="devices_device_config_volume_lock_desc">Qualsiasi cambiamento di volume non fatto tramite questa applicazione sarà resettato mentre il dispositivo è connesso.</string>
    <string name="devices_device_config_volume_lock_override_desc">Il blocco volume sovrascrive attualmente questa funzione.</string>
    <string name="devices_device_config_volume_rate_limiter_label">Limitatore di velocità volume</string>
    <string name="devices_device_config_volume_rate_limiter_desc">Limita la frequenza dei cambiamenti di volume per prevenire regolazioni rapide o eccessive.</string>
