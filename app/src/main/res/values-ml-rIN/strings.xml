    <!-- Onboarding-->
    <string name="onboarding_welcome_title">BVM-ലേക്ക് സ്വാഗതം</string>
    <string name="onboarding_welcome_message">Bluetooth Volume Manager നിങ്ങളുടെ Bluetooth ഉപകരണ വോള്യങ്ങൾ സ്വതോഭൂതമായി നിയന്ത്രിക്കാൻ അനുവദിക്കുന്നു.</string>
    <string name="onboarding_welcome_action">നമുക്ക് പോകാം</string>
    <string name="onboarding_beta_title">ബീറ്റ വേർഷൻ</string>
    <string name="onboarding_beta_message">ഇത് ഒരു ബീറ്റ (ടെസ്റ്റിംഗ്) ബിൽഡാണ്. ഹാസ്യബോധത്തോടെയും ബാക്കപ്പ് പ്ലാനുമായി മുന്നോട്ട് പോകുക. നിങ്ങൾ നേരിടുന്ന പ്രശ്നങ്ങൾ റിപ്പോർട്ട് ചെയ്യുക.</string>
    <string name="onboarding_beta_action">എനിക്ക് ഒന്നും ഭയമില്ല</string>
    <string name="onboarding_privacy_title">സ്വകാര്യത &amp; ഡേറ്റ</string>
    <string name="onboarding_privacy_message">Bluetooth Volume Manager-ൽ പരസ്യങ്ങളൊന്നുമില്ല, ഉപയോക്തൃ ഡേറ്റ വിൽക്കുന്നുമില്ല (ഇത് ഓപ്പൺ-സോഴ്‌സ് കൂടിയാണ്). നിങ്ങളുടെ സ്വകാര്യത എനിക്ക് പ്രധാനമാണ്.</string>
    <string name="onboarding_privacy_read_action">സ്വകാര്യതാ നയം വായിക്കുക</string>
    <string name="onboarding_privacy_action">സ്വീകരിക്കുക</string>
    <string name="onboarding_rewrite_title">ആപ്പ് നവീകരിച്ചു</string>
    <string name="onboarding_rewrite_message">Android മാറ്റങ്ങൾക്കും Google ആവശ്യകതകൾക്കും അനുസരണമായി ആപ്പ് പുനർരചിക്കേണ്ടി വന്നു. വിശ്വസനീയമായി പ്രവർത്തിക്കൽ തുടരുന്നുണ്ടെന്ന് ഉറപ്പാക്കാൻ ആപ്പ് കഴിയുന്നിടത്ത് നവീകരിച്ചു.</string>
    <string name="onboarding_rewrite_features">അപ്ഡേറ്റ് സമയത്ത് ചില ഫീച്ചറുകൾ മാറിയിട്ടുണ്ട്. എല്ലാം ശരിയായി ക്രമീകരിച്ചിട്ടുണ്ടെന്ന് ഉറപ്പാക്കാൻ ദയവായി നിങ്ങളുടെ ഉപകരണ ക്രമീകരണങ്ങൾ പരിശോധിക്കുക.</string>
    <string name="onboarding_rewrite_action">തുടരുക</string>
    <!-- Discover -->
    <string name="discover_no_unmnaged_devices_msg">നിർവ്വഹിക്കാത്ത ഉപകരണങ്ങൾ കണ്ടെത്തിയില്ല</string>
    <string name="discover_all_devices_managed_msg">നിങ്ങളുടെ എല്ലാ ജോടിചേർത്ത ഉപകരണങ്ങളും നിർവ്വഹിക്കുന്നു! ഒരു പുതിയത് വേണോ?</string>
    <string name="discover_pair_new_device_action">പുതിയ ഉപകരണം ജോടിചേർക്കുക</string>
