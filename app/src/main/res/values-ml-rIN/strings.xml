    <string name="devices_device_config_remove_device_label">ഉപകരണം മറക്കുക</string>
    <string name="devices_device_config_remove_device_desc">ഈ ആപ്പിൽ നിന്ന് ഉപകരണം മറക്കുകയും അതിന്റെ ക്രമീകരണം ഇല്ലാതാക്കുകയും ചെയ്യുന്നു. ഇത് ഉപകരണത്തിന്റെ ജോടിചേർൽ നീക്കുന്നില്ല.</string>
    <string name="devices_device_config_remove_device_action">മറക്കുക</string>
    <string name="devices_device_config_remove_device_confirmation">നിർവ്വഹിക്കുന്ന ഉപകരണങ്ങളിൽ നിന്ന് %s മറക്കണോ?</string>
    <string name="devices_device_config_rename_device_label">ഉപകരണം പുനർനാമകരണം ചെയ്യുക</string>
    <string name="devices_device_config_rename_device_desc">ഈ ആപ്പിൽ, സാധ്യമെങ്കിൽ സിസ്റ്റത്തിലും ഈ ഉപകരണം പുനർനാമകരണം ചെയ്യുക.</string>
    <string name="devices_device_config_rename_device_action">പുനർനാമകരണം</string>
    <string name="devices_device_config_enabled_label">പ്രവർത്തനക്ഷമം</string>
    <string name="devices_device_config_enabled_desc">കണക്‌റ് ചെയ്യുമ്പോൾ ഈ ഉപകരണത്തിനോട് പ്രതികരിക്കുക</string>
    <string name="devices_device_config_section_timing_label">സമയക്രമം</string>
    <string name="devices_device_config_monitoring_duration_label">നിരീക്ഷണ ദൈർഘ്യം</string>
    <string name="devices_device_config_monitoring_duration_desc">ക്രമീകരണങ്ങൾ വരുത്തിയ ശേഷം, കൂടുതൽ വോള്യം മാറ്റങ്ങൾ തടയുന്ന സമയ ദൈർഘ്യം മില്ലിസെക്കൻഡിൽ.</string>
    <string name="devices_device_config_adjustment_delay_label">ക്രമീകരണ കാലതാമസം</string>
    <string name="devices_device_config_adjustment_delay_desc">ഓരോ വോള്യം ക്രമീകരണത്തിനുമിടയിലെ കാലതാമസം മില്ലിസെക്കൻഡിൽ. 0ms കാലതാമസം അർത്ഥമാക്കുന്നത് ഈ ഉപകരണം കണക്‌റ് ചെയ്യുമ്പോൾ ഉടൻ വോള്യം സജ്ജീകരിക്കും എന്നാണ്.</string>
    <string name="devices_device_config_reaction_delay_label">പ്രതികരണ കാലതാമസം</string>
    <string name="devices_device_config_reaction_delay_desc">ഈ ആപ്പ് ഈ ഉപകരണത്തിനോട് പ്രതികരിക്കുന്നതിനുള്ള കാലതാമസം മില്ലിസെക്കൻഡിൽ.</string>
    <string name="devices_device_config_section_reaction_label">പ്രതികരണം</string>
    <string name="devices_device_config_launch_app_label">ആപ്പുകൾ തുറക്കുക</string>
    <string name="devices_device_config_launch_app_desc">ഈ ഉപകരണം കണക്‌റ് ചെയ്യുമ്പോൾ ആപ്പുകൾ തുറക്കുക.</string>
    <string name="devices_device_config_launch_app_multiple_desc">%d ആപ്പുകൾ തിരഞ്ഞെടുത്തു</string>
    <string name="devices_device_config_show_home_screen_label">ഹോം സ്ക്രീൻ കാണിക്കുക</string>
    <string name="devices_device_config_show_home_screen_desc">ഈ ഉപകരണത്തിനായുള്ള എല്ലാ ഇവന്റുകളും പ്രോസസ് ചെയ്ത ശേഷം, ഹോം സ്ക്രീൻ കാണിക്കാൻ ശ്രമിക്കുക. ഇത് എല്ലാ Android വേർഷനുകളിലും പ്രവർത്തിക്കില്ലായിരിക്കാം.</string>
    <string name="devices_device_config_nudge_volume_label">വോള്യം നഡ്ജ് ചെയ്യുക</string>
    <string name="devices_device_config_nudge_volume_description">ആവശ്യമായ വോള്യം ഇതിനകം സജ്ജീകരിച്ചിട്ടുണ്ടെങ്കിൽ പോലും (സിസ്റ്റം അനുസരിച്ച്), വോള്യം ഒരു ഘട്ടം കുറച്ചിട്ട് ഉയർത്തുക.</string>
    <string name="devices_device_config_visible_adjustments_label">ദൃശ്യ ക്രമീകരണങ്ങൾ</string>
    <string name="devices_device_config_visible_adjustments_desc">ഈ ആപ്പ് ഈ ഉപകരണത്തിനായി ക്രമീകരണങ്ങൾ നടത്തുമ്പോൾ സിസ്റ്റത്തിന്റെ വോള്യം വിൻഡോ കാണിക്കുക.</string>
    <string name="devices_device_config_keep_awake_label">ഉണർന്നിരിക്കുക</string>
    <string name="devices_device_config_keep_awake_desc">കണക്‌റ് ആയിരിക്കുമ്പോൾ ഉപകരണം ഉണർന്നിരിക്കാൻ ശ്രമിക്കുക. Android വേർഷൻ അനുസരിച്ച് പ്രവർത്തനം വ്യത്യാസപ്പെടാം.</string>
    <string name="devices_device_config_volume_observe_label">മാറ്റങ്ങൾ നിരീക്ഷിക്കുക</string>
    <string name="devices_device_config_volume_observe_desc">ഈ ഉപകരണം കണക്‌റ് ആയിരിക്കുമ്പോൾ സജീവമായിരിക്കുകയും ഈ ആപ്പ് കാരണമല്ലാത്ത വോള്യം മാറ്റങ്ങൾ സംരക്ഷിക്കുകയും ചെയ്യുക.</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">ഡിസ്‌കണക്‌റ് ചെയ്യുമ്പോൾ വോള്യം സംരക്ഷിക്കുക</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">ഈ ഉപകരണം ഡിസ്‌കണക്‌റ് ചെയ്യുമ്പോൾ നിലവിലെ വോള്യം നിലകൾ ക്യാപ്ചർ ചെയ്ത് സംരക്ഷിക്കുക.</string>
    <string name="devices_device_config_volume_lock_label">വോള്യം ലോക്ക്</string>
    <string name="devices_device_config_volume_lock_desc">ഈ ഉപകരണം കണക്‌റ് ആയിരിക്കുമ്പോൾ ഈ ആപ്പ് വഴിയല്ലാതെ വരുത്തുന്ന വോള്യം മാറ്റങ്ങൾ പഴയപടിയാകും.</string>
    <string name="devices_device_config_volume_rate_limiter_label">വോള്യം നിരക്ക് നിയന്ത്രണി</string>
    <string name="devices_device_config_volume_rate_limiter_desc">അതിവേഗ അല്ലെങ്കിൽ അമിത വോള്യം ക്രമീകരണങ്ങൾ തടയാൻ വോള്യം മാറ്റങ്ങളുടെ ആവൃത്തി പരിമിതപ്പെടുത്തുക.</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_label">വോള്യം വർദ്ധന കാലതാമസം</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_desc">വോള്യം വർദ്ധനകൾക്കിടയിലെ കുറഞ്ഞ സമയം: %d ms</string>
    <string name="devices_device_config_volume_rate_limit_decrease_duration_label">വോള്യം കുറയ്ക്കൽ കാലതാമസം</string>
    <string name="devices_device_config_volume_rate_limit_decrease_duration_desc">വോള്യം കുറയ്ക്കലുകൾക്കിടയിലെ കുറഞ്ഞ സമയം: %d ms</string>
    <string name="devices_device_config_autoplay_label">ഓട്ടോപ്ലേ</string>
    <string name="devices_device_config_autoplay_desc">ഈ ഉപകരണം കണക്‌റ് ചെയ്യുമ്പോൾ Bluetooth റിമോട്ടിൽ പ്ലേ അമർത്തുന്നത് അനുകരിക്കുക.</string>
    <string name="devices_device_config_autoplay_keycodes_title">ഓട്ടോപ്ലേ കീ തരങ്ങൾ</string>
    <string name="devices_device_config_autoplay_keycodes_available">ലഭ്യമായ കീ തരങ്ങൾ</string>
    <string name="devices_device_config_autoplay_keycodes_order">തിരഞ്ഞെടുത്ത കീകൾ (ക്രമത്തിൽ)</string>
    <string name="devices_device_config_autoplay_keycodes_label">കീ തരങ്ങൾ</string>
    <string name="devices_device_config_autoplay_keycodes_desc">ഏതൊക്കെ കീകൾ അയക്കണം, ഏതു ക്രമത്തിൽ എന്ന് ക്രമീകരിക്കുക</string>
    <string name="devices_device_config_autoplay_keycodes_none_set">കീകൾ ഒന്നും ക്രമീകരിച്ചിട്ടില്ല</string>
    <string name="devices_device_config_section_volumes_label">വോള്യങ്ങൾ</string>
    <string name="devices_device_config_section_volume_label">വോള്യം</string>
    <string name="devices_device_config_alarm_volume_label">അലാം വോള്യം</string>
    <string name="devices_device_config_alarm_volume_desc">ചില അലാം ആപ്പുകൾ പകരം മ്യൂസിക് വോള്യം ഉപയോഗിക്കുന്നു.</string>
    <string name="devices_device_config_notification_volume_label">നോട്ടിഫിക്കേഷൻ വോള്യം</string>
    <string name="devices_device_config_notification_volume_desc">എല്ലാ ഉപകരണങ്ങളും പ്രത്യേക നോട്ടിഫിക്കേഷൻ വോള്യം ക്രമീകരണം പിന്തുണയ്ക്കുന്നില്ല. നിശ്ശബ്ദ അല്ലെങ്കിൽ വൈബ്രേറ്റ് മോഡും സജ്ജീകരിക്കാം.</string>
    <string name="devices_device_config_music_volume_label">മ്യൂസിക് വോള്യം</string>
    <string name="devices_device_config_music_volume_desc">ഈ ഉപകരണം കണക്‌റ് ചെയ്യുമ്പോൾ സംഗീതത്തെയും ഗെയിമുകളെയും ബാധിക്കുന്ന വോള്യം നിയന്ത്രിക്കുക.</string>
    <string name="devices_device_config_call_volume_label">കോൾ വോള്യം</string>
