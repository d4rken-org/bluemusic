    <string name="devices_device_config_show_home_screen_desc">Nadat alle gebeure vir hierdie toestel verwerk is, probeer om die tuisskerm te wys. Dit werk moontlik nie op alle Android-weergawes nie.</string>
    <string name="devices_device_config_nudge_volume_label">Volume stootjie</string>
    <string name="devices_device_config_nudge_volume_description">Verlaag en verhoog dan die volume met een stap, selfs as die gewenste volume (volgens die stelsel) reeds ingestel is.</string>
    <string name="devices_device_config_visible_adjustments_label">Sigbare aanpassings</string>
    <string name="devices_device_config_visible_adjustments_desc">Wys die stelsel se volume venster terwyl hierdie app aanpassings maak vir hierdie toestel.</string>
    <string name="devices_device_config_keep_awake_label">Hou wakker</string>
    <string name="devices_device_config_keep_awake_desc">Probeer om die toestel wakker te hou terwyl dit gekoppel is. Gedrag kan verskil afhangende van die Android-weergawe.</string>
    <string name="devices_device_config_volume_observe_label">Waarneem veranderinge</string>
    <string name="devices_device_config_volume_observe_desc">Bly aktief terwyl hierdie toestel gekoppel is en stoor volumeveranderinge wat nie deur hierdie program veroorsaak is nie.</string>
