    <string name="devices_device_config_volume_lock_label">Volume-slot</string>
    <string name="devices_device_config_volume_lock_desc">Enige volumeveranderinge wat nie deur hierdie program gemaak is nie, sal teruggestel word terwyl hierdie toestel gekoppel is.</string>
    <string name="devices_device_config_volume_lock_override_desc">Volumeslot oorheers tans hierdie funksie.</string>
