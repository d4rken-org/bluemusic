    <string name="devices_device_config_monitoring_duration_desc">\'n Duur in millisekondes, nadat aanpassings gemaak is, waartydens verdere volumeveranderinge geblokkeer word.</string>
    <string name="devices_device_config_adjustment_delay_label">Aanpassing vertraag</string>
    <string name="devices_device_config_adjustment_delay_desc">Die vertraging in millisekondes tussen elke volume aanpassing. \'N vertraging van 0ms beteken om onmiddellik die volume te stel wanneer hierdie toestel koppel.</string>
