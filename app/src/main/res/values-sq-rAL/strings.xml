    <!-- Onboarding-->
    <string name="onboarding_welcome_title">Mirëse në BVM</string>
    <string name="onboarding_welcome_message">Bluetooth Volume Manager të lejon të menaxhosh vëllimin e zërit të pajisjeve Bluetooth në mënyrë automatike.</string>
    <string name="onboarding_welcome_action">Le të shkojmë</string>
    <string name="onboarding_beta_title">Versioni beta</string>
    <string name="onboarding_beta_message">Ky është një ndërtim beta (testimi). Vazhdo me një ndjenjë humori dhe një plan rezervë. Ju lutemi raportoni çështjet që hasni.</string>
    <string name="onboarding_beta_action">Nuk kam frikë nga asgjë</string>
    <string name="onboarding_privacy_title">Privatësia &amp; Të dhënat</string>
    <string name="onboarding_privacy_message">Bluetooth Volume Manager nuk ka reklama dhe nuk shet të dhënat e përdoruesit (është madje i hapur për burim). Privatësia jote është e rëndësishme për mua.</string>
    <string name="onboarding_privacy_read_action">Lexo Politikën e Privatësisë</string>
    <string name="onboarding_privacy_action">Prano</string>
    <string name="onboarding_rewrite_title">Aplikacioni u Modernizua</string>
    <string name="onboarding_rewrite_message">Duhej të e rishkruaj aplikacionin për të qëndruar në hap me ndryshimet e Android dhe kërkesat e Google. Kam modernizuar aplikacionin ku ishte e mundur për të siguruar që të vazhdon të funksionojë në mënyrë të besueshme.</string>
    <string name="onboarding_rewrite_features">Disa veçori kanë ndryshuar gjatë përditësimit. Ju lutemi kontrolloni cilësimet e pajisjes tuaj për të siguruar që gjithçka është konfiguruar saktë.</string>
    <string name="onboarding_rewrite_action">Vazhdo</string>
