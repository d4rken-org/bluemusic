    <string name="devices_device_config_remove_device_label">Harro pajisje</string>
    <string name="devices_device_config_remove_device_desc">Harron pajisjen nga ky aplikacion dhe fshi konfigurimin e saj. Kjo nuk e çiftuan pajisjen.</string>
    <string name="devices_device_config_remove_device_action">Harro</string>
    <string name="devices_device_config_remove_device_confirmation">Harro %s nga pajisjet e menaxhuara?</string>
    <string name="devices_device_config_rename_device_label">Riemëro pajisje</string>
    <string name="devices_device_config_rename_device_desc">Riemëro këtë pajisje brenda këtij aplikacioni, dhe nëse është e mundur, brenda sistemit.</string>
    <string name="devices_device_config_rename_device_action">Riemëro</string>
    <string name="devices_device_config_enabled_label">Aktivizuar</string>
    <string name="devices_device_config_enabled_desc">Reago ndaj kësaj pajisjeje kur lidhet</string>
    <string name="devices_device_config_section_timing_label">Kohëzgjatja</string>
    <string name="devices_device_config_monitoring_duration_label">Kohëzgjatja e monitorimit</string>
    <string name="devices_device_config_monitoring_duration_desc">Një kohëzgjatje në millisekonda, pas përshtatjeve të bëra, gjatë të cilit çdo ndryshim i mëtejshëm i volumit do të bllokohej.</string>
    <string name="devices_device_config_adjustment_delay_label">Vonese përshtatjeje</string>
    <string name="devices_device_config_adjustment_delay_desc">Vonesa në millisekonda midis secilës përshtatjeje të volumit. Një vonese 0ms do të thotë të vendos voluminë në mënyrë të atëhershme kur kjo pajisje lidhet.</string>
    <string name="devices_device_config_reaction_delay_label">Vonese reaksioni</string>
    <string name="devices_device_config_reaction_delay_desc">Vonesa në millisekonda derisa ky aplikacion të reagojë ndaj kësaj pajisjeje.</string>
    <string name="devices_device_config_section_reaction_label">Reaksioni</string>
    <string name="devices_device_config_launch_app_label">Lança aplikacionet</string>
    <string name="devices_device_config_launch_app_desc">Lança aplikacione kur kjo pajisje lidhet.</string>
    <string name="devices_device_config_launch_app_multiple_desc">%d aplikacione të përzgjedhur</string>
    <string name="devices_device_config_show_home_screen_label">Shfaq ekranin fillestar</string>
    <string name="devices_device_config_show_home_screen_desc">Pas përpunimit të të gjitha ngjarjeve për këtë pajisje, provo të shfaq ekranin fillestar. Mund të mos funksionojë në të gjitha versionet e Android.</string>
    <string name="devices_device_config_nudge_volume_label">Lëviz volumin</string>
    <string name="devices_device_config_nudge_volume_description">Ul pastaj ngrit volumin me një rritje, edhe nëse vëllimi i dëshiruar është tashmë vendosur (sipas sistemit).</string>
    <string name="devices_device_config_visible_adjustments_label">Përshtatje të dukshme</string>
    <string name="devices_device_config_visible_adjustments_desc">Shfaq dritaren e volumit të sistemit ndërsa ky aplikacion bën përshtatje për këtë pajisje.</string>
    <string name="devices_device_config_keep_awake_label">Mbaje zgjuar</string>
    <string name="devices_device_config_keep_awake_desc">Provo të mbaje pajisjen zgjuar ndërsa lidhet. Sjellja mund të ndryshojë në varësi të versionit të Android.</string>
    <string name="devices_device_config_volume_observe_label">Mbikëqyr ndryshimet</string>
    <string name="devices_device_config_volume_observe_desc">Qëndro aktiv ndërsa kjo pajisje lidhet dhe ruaj ndryshimet e volumit që nuk janë shkaktuar nga ky aplikacion.</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">Ruaj volumin në shkëputje</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">Kap dhe ruaj nivelet aktuale të volumit kur kjo pajisje shkëputet.</string>
    <string name="devices_device_config_volume_save_on_disconnect_hint">Në disa pajisje, sistemi ndryshon drejtimin e audios para se të mund të lexojmë volumet. Nëse vlerat e ruajtura nuk përputhen me ato që keni vendosur, provoni të aktivizoni \"Vëzhgo ndryshimet e volumit\" Në vend.</string>
    <string name="devices_device_config_volume_lock_label">Zbritje e volumit</string>
    <string name="devices_device_config_volume_lock_desc">Çdo ndryshim i volumit jo i bërë përmes këtij aplikacioni do të kthehet ndërsa kjo pajisje lidhet.</string>
    <string name="devices_device_config_volume_lock_override_desc">Bllokimi i volumit aktualisht mbishkruan këtë funksion.</string>
    <string name="devices_device_config_volume_rate_limiter_label">Limitues norma vëllimi</string>
    <string name="devices_device_config_volume_rate_limiter_desc">Limito frekuencën e ndryshimeve të volumit për të parandaluar përshtatjet e shpejta ose të tepërta të volumit.</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_label">Vonesa rritjeje vëllimi</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_desc">Koha minimale midis rritjeve të volumit: %d ms</string>
    <string name="devices_device_config_volume_rate_limit_decrease_duration_label">Vonesa zvogëlimi vëllumi</string>
    <string name="devices_device_config_volume_rate_limit_decrease_duration_desc">Koha minimale midis zvogëlimeve të volumit: %d ms</string>
    <string name="devices_device_config_autoplay_label">Luajtje automatike</string>
    <string name="devices_device_config_autoplay_desc">Simulo shtypjen e luajtjes në një telekomandë Bluetooth kur kjo pajisje lidhet.</string>
