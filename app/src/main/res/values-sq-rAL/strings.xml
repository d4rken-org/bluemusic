    <string name="devices_device_config_notification_volume_label">Vëllimi i njoftimit</string>
    <string name="devices_device_config_notification_volume_desc">Jo të gjitha pajisjet mbështesin një cilësim të veçantë të volumit të njoftimit. Mund të vendosë edhe modalitetin e heshtur ose vibrimit.</string>
    <string name="devices_device_config_music_volume_label">Vëllimi i muzikës</string>
    <string name="devices_device_config_music_volume_desc">Kontrollo volumin i cili prek muzikën dhe lojërat kur kjo pajisje lidhet.</string>
    <string name="devices_device_config_call_volume_label">Vëllimi i thirrjes</string>
