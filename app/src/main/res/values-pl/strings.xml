    <string name="devices_device_config_show_home_screen_label">Pokaż ekran główny</string>
    <string name="devices_device_config_show_home_screen_desc">Po przetworzeniu wszystkich zdarzeń dla tego urządzenia, spróbuj pokazać ekran główny. Może nie działać na wszystkich wersjach Androida.</string>
    <string name="devices_device_config_nudge_volume_label">Szturchnij głośność</string>
    <string name="devices_device_config_nudge_volume_description">Zmniejsz, a następnie zwiększ głośność o jeden stopień, nawet jeśli pożądana głośność jest już ustawiona (według systemu).</string>
    <string name="devices_device_config_visible_adjustments_label">Widoczne dostosowania</string>
    <string name="devices_device_config_visible_adjustments_desc">Pokazuj systemowe okno głośności, gdy aplikacja dostosowuje głośność dla tego urządzenia.</string>
    <string name="devices_device_config_keep_awake_label">Utrzymaj wybudzony</string>
    <string name="devices_device_config_keep_awake_desc">Zachowuje ekran w stanie wybudzenia, gdy urządzenie jest podłączone.</string>
    <string name="devices_device_config_volume_observe_label">Obserwuj zmiany</string>
    <string name="devices_device_config_volume_observe_desc">Pozostań aktywny, gdy to urządzenie jest połączone i zapisuj zmiany głośności, które nie zostały spowodowane przez tę aplikację.</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">Zapisz głośność przy rozłączeniu</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">Przechwyć i zapisz aktualne poziomy głośności, gdy to urządzenie się rozłączy.</string>
    <string name="devices_device_config_volume_save_on_disconnect_hint">Na niektórych urządzeniach system przełącza routing audio, zanim zdążymy odczytać głośność. Jeśli zapisane wartości nie zgadzają się z tym, co ustawiłeś, spróbuj zamiast tego włączyć „Obserwuj zmiany głośności”.</string>
    <string name="devices_device_config_volume_lock_label">Blokada głośności</string>
    <string name="devices_device_config_volume_lock_desc">Jakiekolwiek zmiany, które nie będą wprowadzane przez aplikację, zostaną cofnięte, gdy urządzenie jest podłączone.</string>
    <string name="devices_device_config_volume_lock_override_desc">Blokada głośności aktualnie zastępuje tę funkcję.</string>
