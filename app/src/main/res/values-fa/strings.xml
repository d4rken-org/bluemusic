    <string name="devices_device_config_volume_observe_label">پایش تغییرات</string>
    <string name="devices_device_config_volume_observe_desc">حین اتصال این دستگاه فعال بمان و تغییرات صدایی که توسط این برنامه ایجاد نشده را ذخیره کن.</string>
