    <string name="devices_device_config_autoplay_keycodes_order">Ընտրված կողբները (խմբագրությամբ)</string>
    <string name="devices_device_config_autoplay_keycodes_label">Կողբի տեսակներ</string>
    <string name="devices_device_config_autoplay_keycodes_desc">Կարգաբերել, թև ինչ կողբներ ուղարկել և ընդ չափավորությամբ</string>
