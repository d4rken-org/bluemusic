    <string name="onboarding_beta_title">Beta versiya</string>
    <string name="onboarding_beta_message">Bu beta (sinov) versiyasidir. Hazil tuyg\'usi va zaxira reja bilan davom eting. Iltimos, duch kelgan muammolarni xabar qiling.</string>
    <string name="onboarding_beta_action">Men hech narsadan qo\'rqmayman</string>
    <string name="onboarding_privacy_title">Maxfiylik va ma\'lumotlar</string>
    <string name="onboarding_privacy_message">Bluetooth Volume Manager reklama ko\'rsatmaydi va foydalanuvchi ma\'lumotlarini sotmaydi (u hatto ochiq kodli). Sizning maxfiyligingiz men uchun muhim.</string>
    <string name="onboarding_privacy_read_action">Maxfiylik siyosatini o\'qish</string>
