    <string name="devices_device_config_nudge_volume_description">Tizim kerakli ovozni allaqachon o\'rnatgan bo\'lsa ham, ovozni bir qadam kamaytiradi, so\'ng ko\'taradi.</string>
    <string name="devices_device_config_visible_adjustments_label">Ko\'rinadigan sozlamalar</string>
    <string name="devices_device_config_visible_adjustments_desc">Bu ilova ushbu qurilma uchun sozlamalar amalga oshirayotganda tizimning ovoz oynasini ko\'rsatish.</string>
