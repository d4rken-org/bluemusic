    <string name="devices_device_config_volume_save_on_disconnect_desc">Bu qurilma uzilganda joriy ovoz darajalarini olish va saqlash.</string>
    <string name="devices_device_config_volume_save_on_disconnect_hint">Ba\'zi qurilmalarda tizim ovoz balandligini o\'qishdan oldin audio marshrutni almashtiradi. Agar saqlangan qiymatlar siz o\'rnatgan qiymatga mos kelmasa, uning o\'rniga \"Ovoz balandligi o\'zgarishlarini kuzatish\" opsiyasini yoqib ko\'ring.</string>
    <string name="devices_device_config_volume_lock_label">Ovoz qulfi</string>
    <string name="devices_device_config_volume_lock_desc">Bu qurilma ulanganda ushbu ilova orqali amalga oshirilmagan barcha ovoz o\'zgarishlari bekor qilinadi.</string>
    <string name="devices_device_config_volume_lock_override_desc">Ovoz qulfi hozirda bu funksiyani bekor qilmoqda.</string>
