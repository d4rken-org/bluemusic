    <string name="devices_device_config_label">சாதன அமைப்பு</string>
    <string name="devices_device_config_section_general_label">பொது</string>
    <string name="devices_device_config_remove_device_label">சாதனத்தை மறந்துவிடு</string>
    <string name="devices_device_config_remove_device_desc">இந்த ஆப்்அலிருந்து சாதனத்தை மறந்து அதன் அமைப்பை நீக்கிவிடுகிறது. இது சாதனத்தை இணைப்பை நீக்காது.</string>
    <string name="devices_device_config_remove_device_action">மறந்துவிடு</string>
    <string name="devices_device_config_remove_device_confirmation">%s-அய் நிர்வகிக்கப்பட்ட சாதனங்களிலிருந்து மறந்துவிடலாமா?</string>
    <string name="devices_device_config_rename_device_label">சாதனத்தை மறுபெயரிடு</string>
    <string name="devices_device_config_rename_device_desc">இந்த ஆப்்அல் உள்ளேயும், முடிந்தால், கணினி உள்ளேயும் சாதனத்தை மறுபெயரிடுகிறது.</string>
    <string name="devices_device_config_rename_device_action">மறுபெயரிடு</string>
    <string name="devices_device_config_enabled_label">இயக்கப்பட்ட</string>
    <string name="devices_device_config_enabled_desc">இந்த சாதனம் இணைக்கப்பட்டால் ப்ரதிகிரியுங்கள்</string>
    <string name="devices_device_config_section_timing_label">நேரம்</string>
    <string name="devices_device_config_monitoring_duration_label">கண்காணிப்பு காலஅளவு</string>
    <string name="devices_device_config_monitoring_duration_desc">சரிசெய்த்தல்கள் மேற்கொள்ளப்பட்ட பிறகு, கூடுதலான ஒலி அளவு மாற்றங்கள் தடுக்கப்படும் மில்லிவிநாடிகளில் காலஅளவு.</string>
    <string name="devices_device_config_adjustment_delay_label">சரிசெய்த்தல் தாமதம்</string>
    <string name="devices_device_config_adjustment_delay_desc">ஒவ்வொரு ஒலி அளவு சரிசெய்த்தல்கும் இடையிலான மில்லிவிநாடிகளில் தாமதம். 0ms தாமதம் இந்த சாதனம் இணைக்கப்படும்போது உடனடியாக ஒலி அளவு அமைக்கப்படும் என்பதைக் குறிக்கிறது.</string>
    <string name="devices_device_config_reaction_delay_label">ப்ரதிகிரியிற்கு தாமதம்</string>
    <string name="devices_device_config_reaction_delay_desc">இந்த ஆப்் இந்த சாதனத்திற்கு ப்ரதிகிரிக்கும் வரையிலான மில்லிவிநாடிகளில் தாமதம்.</string>
    <string name="devices_device_config_section_reaction_label">ப்ரதிகிரியிற்கு</string>
    <string name="devices_device_config_launch_app_label">ஆப்களை தொடங்கு</string>
    <string name="devices_device_config_launch_app_desc">இந்த சாதனம் இணைக்கப்படும்போது ஆப்களை தொடங்கு.</string>
    <string name="devices_device_config_launch_app_multiple_desc">%d ஆப்கள் தேர்ந்தெடுக்கப்பட்டன</string>
    <string name="devices_device_config_show_home_screen_label">இல்ல திரையைக் காட்டு</string>
    <string name="devices_device_config_show_home_screen_desc">இந்த சாதனத்திற்கான அனைத்து நிகழ்வுகளும் செயலாக்கப்பட்ட பிறகு இல்ல திரையைக் காட்ட முயற்சிக்கும். இது அனைத்து Android பதிப்புகளிலும் இயங்காது.</string>
    <string name="devices_device_config_nudge_volume_label">ஒலி அளவை நகர்த்து</string>
    <string name="devices_device_config_nudge_volume_description">கணினியில் இல்லாமல் ஒலி அளவை ஒரு மட்டம் குறைத்து பின் உயர்த்துகிறது, என்பது கேட்டப்பட்ட ஒலி அளவு ஏற்கனவே அமைக்கப்பட்டிருந்தாலும் (கணினியின் படி).</string>
    <string name="devices_device_config_visible_adjustments_label">காணும் சரிசெய்த்தல்கள்</string>
    <string name="devices_device_config_visible_adjustments_desc">இந்த ஆப்் இந்த சாதனத்திற்காக சரிசெய்த்தல்கள் செய்யும்போது கணினியின் ஒலி சாளர்த்தைக் காட்டு.</string>
    <string name="devices_device_config_keep_awake_label">விழிப்பாக வை</string>
    <string name="devices_device_config_keep_awake_desc">இணைக்கப்பட்டிருக்கும்போது சாதனத்தை விழிப்பாக வைக்க முயற்சிக்கும். ஆற்றல் Android பதிப்பின் படி மாறலாம்.</string>
    <string name="devices_device_config_volume_observe_label">மாற்றங்களைக் கவனி</string>
    <string name="devices_device_config_volume_observe_desc">இந்த சாதனம் இணைக்கப்பட்டிருக்கும்போது உல்னிலையிருக்கும் மற்றும் இந்த ஆப்்இனால் ஏற்படாத ஒலி மாற்றங்களை சேமிக்கும்.</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">தொடர்பு துணிக்கத்தில் ஒலி அளவை சேமி</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">இந்த சாதனம் தொடர்பு துணிக்கப்படும்போது தற்போதுள்ள ஒலி அளவுகளைக் குறித்து சேமிக்கும்.</string>
    <string name="devices_device_config_volume_lock_label">ஒலி பூட்டு</string>
    <string name="devices_device_config_volume_lock_desc">இந்த சாதனம் இணைக்கப்பட்டிருக்கும்போது இந்த ஆப் அன்றி மாற்றப்பட்ட ஒலி மாற்றங்கள் உதாரணமாக மாற்றப்படும்.</string>
    <string name="devices_device_config_volume_rate_limiter_label">ஒலி விகித கட்டுப்பாடு</string>
    <string name="devices_device_config_volume_rate_limiter_desc">விரைவாக மற்றும் அதிகமாக ஒலி சரிசெய்த்தல்களைத் தடுக்க ஒலி மாற்றங்களின் அலைவீச்சைக் கட்டுப்படுத்து.</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_label">ஒலி ஐர்த்தல் தாமதம்</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_desc">ஒலி ஐர்த்தல்களுக்கும் இடையிலான குறைந்தபட்ச நேரம்: %d ms</string>
    <string name="devices_device_config_volume_rate_limit_decrease_duration_label">ஒலி குறைய்தல் தாமதம்</string>
    <string name="devices_device_config_volume_rate_limit_decrease_duration_desc">ஒலி குறைய்தல்களுக்கும் இடையிலான குறைந்தபட்ச நேரம்: %d ms</string>
    <string name="devices_device_config_autoplay_label">தானியங்கு இசைப்பிச்சு</string>
    <string name="devices_device_config_autoplay_desc">இந்த சாதனம் இணைக்கப்படும்போது Bluetooth ரிமோட்டில் இசை படுத்து பட்டனை அதிக்கும் படி பழகுவெஒக்கும்.</string>
    <string name="devices_device_config_autoplay_keycodes_title">தானியங்கு இசைப்பிச்சு உலை வகைகள்</string>
    <string name="devices_device_config_autoplay_keycodes_available">கிடைக்கக்கூடிய உலை வகைகள்</string>
    <string name="devices_device_config_autoplay_keycodes_order">தேர்ந்தெடுக்கப்பட்ட உலைகள் (வரிசைப்படி)</string>
    <string name="devices_device_config_autoplay_keycodes_label">உலை வகைகள்</string>
    <string name="devices_device_config_autoplay_keycodes_desc">எந்த உலைகளை அனுப்பினால் எங்கெ அந்த வரிசையில் அனுப்பவென்பதைக் கட்டமைக்கும்</string>
    <string name="devices_device_config_autoplay_keycodes_none_set">உலைகள் கட்டமைக்கப்படவில்லை</string>
    <string name="devices_device_config_section_volumes_label">ஒலி அளவுகள்</string>
    <string name="devices_device_config_section_volume_label">ஒலி அளவு</string>
    <string name="devices_device_config_alarm_volume_label">அலாரம் ஒலி அளவு</string>
    <string name="devices_device_config_alarm_volume_desc">சில அலாரம் ஆப்கள் கத்தி ஒலி அளவைப் பயன்படுத்துகின்றன.</string>
    <string name="devices_device_config_notification_volume_label">அறிவிப்பு ஒலி அளவு</string>
    <string name="devices_device_config_notification_volume_desc">அனைத்து சாதனங்களும் தனி அறிவிப்பு ஒலி அமைப்பை ஆதரிக்கவில்லை. மௌனம் அல்லது கம்பனம் வித்தியாசத்தையும் அமைக்கலாம்.</string>
    <string name="devices_device_config_music_volume_label">இசை ஒலி அளவு</string>
    <string name="devices_device_config_music_volume_desc">இந்த சாதனம் இணைக்கப்படும்போது இசை மற்றும் விளையாட்டுகளை பாதிக்கும் ஒலி அளவைக் கட்டுப்படுத்து.</string>
    <string name="devices_device_config_call_volume_label">அழைப்பு ஒலி அளவு</string>
    <string name="devices_device_config_call_volume_desc">இந்த சாதனம் இணைக்கப்படும்போது அழைப்புகளை பாதிக்கும் ஒலி அளவைக் கட்டுப்படுத்து.</string>
    <string name="devices_device_config_ring_volume_label">ரிங் ஒலி அளவு</string>
    <string name="devices_device_config_ring_volume_desc">உங்கள் ரிங்டோனை பாதிக்கும் ஒலி அளவைக் கட்டுப்படுத்து. மௌனம் அல்லது கம்பனம் வித்தியாசத்தையும் அமைக்கலாம்.</string>
    <string name="devices_device_config_notification_policy_required_ringtone">ரிங் ஒலி கட்டுப்பாடுக்கு அறிவிப்பு கொள்கை அணுகல் தேவைப்படுகிறது</string>
    <string name="devices_device_config_notification_policy_required_notification">அறிவிப்பு ஒலி கட்டுப்பாடுக்கு அறிவிப்பு கொள்கை அணுகல் தேவைப்படுகிறது</string>
    <string name="devices_device_config_notification_policy_required_dnd">தொல்லை தராதெ கட்டுப்பாடுக்கு அறிவிப்பு கொள்கை அணுகல் தேவைப்படுகிறது</string>
    <string name="devices_device_config_notification_policy_action">அணுகலை வழங்கு</string>
