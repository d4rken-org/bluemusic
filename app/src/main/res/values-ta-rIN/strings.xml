    <string name="dnd_mode_dialog_title">DND வித்தியாசத்தைத் தேர்ந்தெடு</string>
    <string name="dnd_mode_dont_change">மாற்றாதே இரு</string>
    <string name="dnd_mode_off">அணைய்</string>
    <string name="dnd_mode_priority_only">முன்னுரிமை மட்டுமே</string>
    <string name="dnd_mode_alarms_only">அலாரம்கள் மட்டுமே</string>
    <string name="dnd_mode_total_silence">முழு மௌனம்</string>
