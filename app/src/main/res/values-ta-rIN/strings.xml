    <!-- Onboarding-->
    <string name="onboarding_welcome_title">BVM-க்கு வரவேற்கிறோம்</string>
    <string name="onboarding_welcome_message">Bluetooth Volume Manager உங்கள் Bluetooth சாதன ஒலி அளவை தானாகவே நிர்வகிக்க உதவுகிறது.</string>
    <string name="onboarding_welcome_action">தொடங்குவோம்</string>
    <string name="onboarding_beta_title">பீட்டா பதிப்பு</string>
    <string name="onboarding_beta_message">இது ஒரு பீட்டா (சோதனை) உருவாக்கம். நகைச்சுவை உணர்வு மற்றும் மாற்று திட்டத்துடன் தொடரவும். நீங்கள் சந்திக்கும் சிக்கல்களைப் புகாரளிக்கவும்.</string>
    <string name="onboarding_beta_action">நான் எதற்கும் பயப்படவில்லை</string>
    <string name="onboarding_privacy_title">தனியுரிமை &amp; தரவு</string>
    <string name="onboarding_privacy_message">Bluetooth Volume Manager-ல் விளம்பரங்கள் இல்லை மற்றும் பயனர் தரவை விற்கவில்லை (இது திறந்த மூலமாகும்). உங்கள் தனியுரிமை எனக்கு முக்கியம்.</string>
    <string name="onboarding_privacy_read_action">தனியுரிமைக் கொள்கையைப் படிக்கவும்</string>
    <string name="onboarding_privacy_action">ஏற்கு</string>
    <string name="onboarding_rewrite_title">ஆப் நவீனமாக்கப்பட்டது</string>
    <string name="onboarding_rewrite_message">Android மாற்றங்கள் மற்றும் Google தேவைகளுக்கு ஏற்பட்டாக ஆப்்அன்னை மூளை நான் முழுமையாக எழுதினேன். நம்பகமாக தொடரந்து இயங்கப்பட இயலுமிடத்தில் ஆப்்அன்னை நவீனப்படுத்திகிறேன்.</string>
    <string name="onboarding_rewrite_features">மேம்பாடு மூலம் சில விஷயங்கள் மாறியுள்ளன. அந்த விஷயங்கள் சரியாக அமைக்கப்பட்டுள்ளதாக உறுதிப்படுத்த உங்கள் சாதன அமைப்புகளைச் செக்கவும்.</string>
    <string name="onboarding_rewrite_action">தொடர்</string>
    <!-- Discover -->
    <string name="discover_no_unmnaged_devices_msg">நிர்வகிக்கப்படாத சாதனங்கள் ஏதும் காணப்படவில்லை</string>
    <string name="discover_all_devices_managed_msg">உங்கள் எல்லா இணைக்கப்பட்ட சாதனங்களும் நிர்வகிக்கப்படுகின்றன! புதிதாக ஒன்று தேவையா?</string>
    <string name="discover_pair_new_device_action">புதிய சாதனத்தை இணைக்கவும்</string>
