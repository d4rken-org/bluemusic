    <string name="devices_device_config_nudge_volume_label">Дууг өших</string>
    <string name="devices_device_config_nudge_volume_description">Системд аль худалдсан ижил дууг оноогосон байса ч дуугаа нэг нэгжийг негжүүлнээд оруулах.</string>
