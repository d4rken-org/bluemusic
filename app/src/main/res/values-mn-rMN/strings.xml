    <string name="devices_device_config_keep_awake_label">Сэржүүлээр байлгаах</string>
    <string name="devices_device_config_keep_awake_desc">Холбогдсон үед төхөөрөмжийг сэржүүлээр байлгаахыг оролдуула. Android-ын хувилбараас шалтгаалт өөрчөгдөнө.</string>
