    <!-- Onboarding-->
    <string name="onboarding_welcome_title">BVM मध्ये आपले स्वागत आहे</string>
    <string name="onboarding_welcome_message">Bluetooth Volume Manager आपल्याला Bluetooth डिव्हाइसचे व्हॉल्युम आपोआप व्यवस्थापित करण्याची परवानगी देतो.</string>
    <string name="onboarding_welcome_action">चला जाऊया</string>
    <string name="onboarding_beta_title">बीटा आवृत्ती</string>
    <string name="onboarding_beta_message">हे एक बीटा (चाचणी) बिल्ड आहे. विनोदाच्या भावनेने आणि बॅकअप योजनेसह पुढे जा. कृपया आपल्याला आढळलेल्या समस्या नोंदवा.</string>
    <string name="onboarding_beta_action">मला कशाचीही भीती नाही</string>
    <string name="onboarding_privacy_title">गोपनीयता आणि डेटा</string>
    <string name="onboarding_privacy_message">Bluetooth Volume Manager मध्ये कोणतीही जाहिरात नाही आणि तो वापरकर्त्याचा डेटा विकत नाही (हे ओपन-सोर्स देखील आहे). तुमची गोपनीयता माझ्यासाठी महत्त्वाची आहे.</string>
    <string name="onboarding_privacy_read_action">गोपनीयता धोरण वाचा</string>
    <string name="onboarding_privacy_action">स्वीकारा</string>
    <string name="onboarding_rewrite_title">अॅप आधुनिक केला</string>
    <string name="onboarding_rewrite_message">Android बदल आणि Google आवश्यकतांशी जुळवून घेण्यासाठी मला अॅप पुन्हा लिहावा लागला. अॅप विश्वसनीयपणे काम करत राहील याची खात्री करण्यासाठी मी शक्य तेथे तो आधुनिक केला आहे.</string>
    <string name="onboarding_rewrite_features">अद्यतनादरम्यान काही वैशिष्ट्ये बदलली आहेत. कृपया सर्व काही योग्यरित्या कॉन्फिगर केले आहे याची खात्री करण्यासाठी आपल्या डिव्हाइसच्या सेटिंग्ज तपासा.</string>
    <string name="onboarding_rewrite_action">सुरू ठेवा</string>
    <!-- Discover -->
    <string name="discover_no_unmnaged_devices_msg">कोणतेही अव्यवस्थापित डिव्हाइस आढळले नाही</string>
    <string name="discover_all_devices_managed_msg">तुमची सर्व जोडलेली डिव्हाइस व्यवस्थापित आहेत! नवीन हवे आहे का?</string>
    <string name="discover_pair_new_device_action">नवीन डिव्हाइस जोडा</string>
    <!-- Devices -->
    <string name="devices_device_config_label">डिव्हाइस कॉन्फिगरेशन</string>
    <string name="devices_device_config_section_general_label">सामान्य</string>
    <string name="devices_device_config_remove_device_label">डिव्हाइस विसरा</string>
    <string name="devices_device_config_remove_device_desc">या अॅपमधून डिव्हाइस विसरते आणि त्याचे कॉन्फिगरेशन हटवते. हे डिव्हाइस अनपेअर करत नाही.</string>
    <string name="devices_device_config_remove_device_action">विसरा</string>
    <string name="devices_device_config_remove_device_confirmation">%s ला व्यवस्थापित डिव्हाइसमधून विसरायचे का?</string>
    <string name="devices_device_config_rename_device_label">डिव्हाइसचे नाव बदला</string>
    <string name="devices_device_config_rename_device_desc">या अॅपमध्ये आणि शक्य असल्यास सिस्टेममध्ये या डिव्हाइसचे नाव बदला.</string>
    <string name="devices_device_config_rename_device_action">नाव बदला</string>
    <string name="devices_device_config_enabled_label">सक्षम केले</string>
    <string name="devices_device_config_enabled_desc">कनेक्ट झाल्यावर या डिव्हाइसवर प्रतिक्रिया द्या</string>
    <string name="devices_device_config_section_timing_label">वेळ</string>
    <string name="devices_device_config_monitoring_duration_label">निरीक्षण कालावधी</string>
    <string name="devices_device_config_monitoring_duration_desc">समायोजन केल्यानंतर मिलिसेकंदांमध्ये एक कालावधी, ज्या दरम्यान कोणतेही पुढील व्हॉल्युम बदल अवरोधित केले जातील.</string>
    <string name="devices_device_config_adjustment_delay_label">समायोजन विलंब</string>
    <string name="devices_device_config_adjustment_delay_desc">प्रत्येक व्हॉल्युम समायोजनादरम्यान मिलिसेकंदांमध्ये विलंब. 0ms विलंब म्हणजे हे डिव्हाइस कनेक्ट झाल्यावर लगेच व्हॉल्युम सेट करणे.</string>
    <string name="devices_device_config_reaction_delay_label">प्रतिक्रिया विलंब</string>
    <string name="devices_device_config_reaction_delay_desc">हा अॅप या डिव्हाइसवर प्रतिक्रिया देईपर्यंतचा मिलिसेकंदांमध्ये विलंब.</string>
    <string name="devices_device_config_section_reaction_label">प्रतिक्रिया</string>
    <string name="devices_device_config_launch_app_label">अॅप सुरू करा</string>
    <string name="devices_device_config_launch_app_desc">हे डिव्हाइस कनेक्ट झाल्यावर अॅप सुरू करा.</string>
    <string name="devices_device_config_launch_app_multiple_desc">%d अॅप निवडले</string>
    <string name="devices_device_config_show_home_screen_label">होम स्क्रीन दाखवा</string>
    <string name="devices_device_config_show_home_screen_desc">या डिव्हाइससाठी सर्व इव्हेंट प्रक्रिया झाल्यानंतर, होम स्क्रीन दाखवण्याचा प्रयत्न करा. हे सर्व Android आवृत्त्यांवर कार्य करणार नाही.</string>
    <string name="devices_device_config_nudge_volume_label">व्हॉल्युम थोडे बदला</string>
    <string name="devices_device_config_nudge_volume_description">व्हॉल्युम एक वाढीने कमी करा आणि नंतर वाढवा, जरी इच्छित व्हॉल्युम आधीच सेट केले असले (सिस्टमनुसार).</string>
    <string name="devices_device_config_visible_adjustments_label">दृश्यमान समायोजने</string>
    <string name="devices_device_config_visible_adjustments_desc">हा अॅप या डिव्हाइससाठी समायोजने करत असताना सिस्टमचे व्हॉल्युम विंडो दाखवा.</string>
    <string name="devices_device_config_keep_awake_label">जागे ठेवा</string>
    <string name="devices_device_config_keep_awake_desc">कनेक्ट असताना डिव्हाइस जागे ठेवण्याचा प्रयत्न करा. Android आवृत्तीनुसार वर्तन बदलू शकते.</string>
    <string name="devices_device_config_volume_observe_label">बदल निरीक्षण करा</string>
    <string name="devices_device_config_volume_observe_desc">हे डिव्हाइस कनेक्ट असताना सक्रिय राहा आणि या अॅपमुळे न झालेले व्हॉल्युम बदल जतन करा.</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">डिस्कनेक्ट झाल्यावर व्हॉल्युम जतन करा</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">हे डिव्हाइस डिस्कनेक्ट झाल्यावर सध्याच्या व्हॉल्युम पातळी कॅप्चर करा आणि जतन करा.</string>
    <string name="devices_device_config_volume_save_on_disconnect_hint">काही डिव्हाइसवर, आम्ही व्हॉल्यूम वाचण्यापूर्वी सिस्टम ऑडिओ रूटिंग बदलते. जर जतन केलेली मूल्ये तुम्ही सेट केलेल्याशी जुळत नसतील, तर त्याऐवजी \"व्हॉल्यूम बदल निरीक्षण करा\" सक्षम करण्याचा प्रयत्न करा.</string>
    <string name="devices_device_config_volume_lock_label">व्हॉल्युम लॉक</string>
    <string name="devices_device_config_volume_lock_desc">या अॅपद्वारे न केलेले कोणतेही व्हॉल्युम बदल हे डिव्हाइस कनेक्ट असताना परत केले जातील.</string>
    <string name="devices_device_config_volume_lock_override_desc">व्हॉल्युम लॉक सध्या या वैशिष्ट्याला ओव्हरराइड करत आहे.</string>
    <string name="devices_device_config_volume_rate_limiter_label">व्हॉल्युम दर मर्यादक</string>
    <string name="devices_device_config_volume_rate_limiter_desc">जलद किंवा अत्याधिक व्हॉल्युम समायोजन टाळण्यासाठी व्हॉल्युम बदलांची वारंवारिता मर्यादित करा.</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_label">व्हॉल्युम वाढ विलंब</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_desc">व्हॉल्युम वाढींमधील किमान वेळ: %d ms</string>
    <string name="devices_device_config_volume_rate_limit_decrease_duration_label">व्हॉल्युम कमी विलंब</string>
    <string name="devices_device_config_volume_rate_limit_decrease_duration_desc">व्हॉल्युम घटींमधील किमान वेळ: %d ms</string>
    <string name="devices_device_config_autoplay_label">स्वयंप्ले</string>
    <string name="devices_device_config_autoplay_desc">हे डिव्हाइस कनेक्ट झाल्यावर Bluetooth रिमोटवर प्ले दाबण्याचे अनुकरण करा.</string>
    <string name="devices_device_config_autoplay_keycodes_title">स्वयंप्ले की प्रकार</string>
    <string name="devices_device_config_autoplay_keycodes_available">उपलब्ध की प्रकार</string>
    <string name="devices_device_config_autoplay_keycodes_order">निवडलेल्या की (क्रमाने)</string>
    <string name="devices_device_config_autoplay_keycodes_label">की प्रकार</string>
    <string name="devices_device_config_autoplay_keycodes_desc">कोणत्या की पाठवायच्या आणि कोणत्या क्रमाने ते कॉन्फिगर करा</string>
    <string name="devices_device_config_autoplay_keycodes_none_set">कोणत्याही की कॉन्यिगर केल्या नाहीत</string>
    <string name="devices_device_config_section_volumes_label">व्हॉल्युम्स</string>
    <string name="devices_device_config_section_volume_label">व्हॉल्युम</string>
    <string name="devices_device_config_alarm_volume_label">अलार्म व्हॉल्युम</string>
    <string name="devices_device_config_alarm_volume_desc">काही अलार्म अॅप्स त्याएवजी म्युझिक व्हॉल्युम वापरतात.</string>
    <string name="devices_device_config_notification_volume_label">सूचना व्हॉल्युम</string>
    <string name="devices_device_config_notification_volume_desc">सर्व डिव्हाइस स्वतंत्र सूचना व्हॉल्युम सेटिंग समर्थन करत नाहीत. सायलेंट किंवा व्हायब्रेट मोड देखील सेट करता येतो.</string>
    <string name="devices_device_config_music_volume_label">म्युझिक व्हॉल्युम</string>
    <string name="devices_device_config_music_volume_desc">हे डिव्हाइस कनेक्ट झाल्यावर संगीत आणि गेम्सवर परिणाम करणारे व्हॉल्युम नियंत्रित करा.</string>
    <string name="devices_device_config_call_volume_label">कॉल व्हॉल्युम</string>
    <string name="devices_device_config_call_volume_desc">हे डिव्हाइस कनेक्ट झाल्यावर कॉल्सवर परिणाम करणारे व्हॉल्युम नियंत्रित करा.</string>
    <string name="devices_device_config_ring_volume_label">रिंग व्हॉल्युम</string>
    <string name="devices_device_config_ring_volume_desc">तुमच्या रिंगटोनवर परिणाम करणारे व्हॉल्युम नियंत्रित करा. सायलेंट किंवा व्हायब्रेट मोड देखील सेट करता येतो.</string>
    <string name="devices_device_config_notification_policy_required_ringtone">रिंग व्हॉल्युम नियंत्रणासाठी सूचना धोरण प्रवेश आवश्यक आहे</string>
    <string name="devices_device_config_notification_policy_required_notification">सूचना व्हॉल्युम नियंत्रणासाठी सूचना धोरण प्रवेश आवश्यक आहे</string>
    <string name="devices_device_config_notification_policy_required_dnd">डू नॉट डिस्टर्ब नियंत्रणासाठी सूचना धोरण प्रवेश आवश्यक आहे</string>
