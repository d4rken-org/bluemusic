    <string name="devices_device_config_autoplay_label">स्वतः प्ले</string>
    <string name="devices_device_config_autoplay_desc">यो यन्त्र जडान हुँदा कन्फिगर गरिएका मिडिया कुञ्जी आदेशहरू पठाउनुहोस्।</string>
