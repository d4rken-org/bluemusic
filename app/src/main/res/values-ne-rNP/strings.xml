    <!-- Onboarding-->
    <string name="onboarding_welcome_title">BVM मा स्वागत छ</string>
    <string name="onboarding_welcome_message">Bluetooth Volume Manager ले तपाईंलाई Bluetooth उपकरण भोल्युमहरू स्वचालित रूपमा व्यवस्थापन गर्न अनुमति दिन्छ।</string>
    <string name="onboarding_welcome_action">चलौं</string>
    <string name="onboarding_beta_title">बिटा संस्करण</string>
    <string name="onboarding_beta_message">यो बेटा (परीक्षण) निर्माण हो। हास्यको भावना र बैकअप योजनाको साथ अगाडि बढ्नुहोस्। कृपया तपाईंले सामना गर्ने समस्याहरू रिपोर्ट गर्नुहोस्।</string>
    <string name="onboarding_beta_action">मलाई कुनै डर छैन</string>
    <string name="onboarding_privacy_title">गोपनीयता र डेटा</string>
    <string name="onboarding_privacy_message">Bluetooth Volume Manager मा कुनै विज्ञापन छैन र प्रयोगकर्ता डेटा बिक्री गर्दैन (यो खुला स्रोत पनि हो)। तपाईंको गोपनीयता मेरो लागि महत्त्वपूर्ण छ।</string>
    <string name="onboarding_privacy_read_action">गोपनीयता नीति पढ्नुहोस्</string>
    <string name="onboarding_privacy_action">स्वीकार गर्नुहोस्</string>
    <string name="onboarding_rewrite_title">एप आधुनिकीकरण भयो</string>
    <string name="onboarding_rewrite_message">Android परिवर्तनहरू र Google आवश्यकताहरूसँग तालमेल राख्नको लागि मैले एपलाई पुनर्लेखन गर्नु पर्यो। एप भरोसेमंद रूपमा काम गर्न जारी राखोस् भनेर मैले जहाँ सम्भव भयो आधुनिकीकरण गरेको छु।</string>
    <string name="onboarding_rewrite_features">अपडेटको क्रममा केही सुविधाहरू परिवर्तन भएका छन्। सबै कुरा सही रूपमा कन्फिगर भएको छ भनी सुनिश्चित गर्न कृपया आफ्नो उपकरण सेटिङहरू जाँच गर्नुहोस्।</string>
    <string name="onboarding_rewrite_action">जारी राख्नुहोस्</string>
    <!-- Discover -->
    <string name="discover_no_unmnaged_devices_msg">कुनै अव्यवस्थित उपकरण फेला परेन</string>
    <string name="discover_all_devices_managed_msg">तपाईंका सबै जोडिएका उपकरणहरू व्यवस्थित छन्! नयाँ चाहिन्छ?</string>
    <string name="discover_pair_new_device_action">नयाँ उपकरण जोड्नुहोस्</string>
    <!-- Devices -->
    <string name="devices_device_config_label">उपकरण कन्फिगरेसन</string>
    <string name="devices_device_config_section_general_label">सामान्य</string>
    <string name="devices_device_config_remove_device_label">उपकरण बिर्सनुहोस्</string>
    <string name="devices_device_config_remove_device_desc">यस एपबाट उपकरण बिर्सन्छ र यसको कन्फिगरेसन मेटाउँछ। यसले उपकरण अनपेयर गर्दैन।</string>
    <string name="devices_device_config_remove_device_action">बिर्सनुहोस्</string>
    <string name="devices_device_config_remove_device_confirmation">व्यवस्थित उपकरणहरूबाट %s बिर्स्ने?</string>
    <string name="devices_device_config_rename_device_label">उपकरण पुनर्नाम गर्नुहोस्</string>
    <string name="devices_device_config_rename_device_desc">यस एप भित्र र सम्भव भएमा प्रणालीमा पनि यस उपकरणको नाम परिवर्तन गर्नुहोस्।</string>
    <string name="devices_device_config_rename_device_action">पुनर्नाम गर्नुहोस्</string>
    <string name="devices_device_config_enabled_label">सक्षम</string>
    <string name="devices_device_config_enabled_desc">जडान भएमा यस उपकरणमा प्रतिक्रिया दिनुहोस्</string>
    <string name="devices_device_config_section_timing_label">समय</string>
    <string name="devices_device_config_monitoring_duration_label">निगरानी अवधि</string>
    <string name="devices_device_config_monitoring_duration_desc">मिलिसेकेन्डमा एउटा अवधि, समायोजन गरिसकेपछि, जसमा थप भोल्युम परिवर्तनहरू अवरुद्ध हुनेछन्।</string>
    <string name="devices_device_config_adjustment_delay_label">समायोजन विलम्ब</string>
    <string name="devices_device_config_adjustment_delay_desc">प्रत्येक भोल्युम समायोजनबिचको मिलिसेकेन्डमा विलम्ब। ०ms विलम्बको अर्थ यो उपकरण जडान हुँदा तुरन्त भोल्युम सेट गर्नु हो।</string>
    <string name="devices_device_config_reaction_delay_label">प्रतिक्रिया विलम्ब</string>
    <string name="devices_device_config_reaction_delay_desc">यस एपले यस उपकरणमा प्रतिक्रिया दिनुभन्दा पहिले मिलिसेकेन्डमा विलम्ब।</string>
    <string name="devices_device_config_section_reaction_label">प्रतिक्रिया</string>
    <string name="devices_device_config_launch_app_label">एपहरू खोल्नुहोस्</string>
    <string name="devices_device_config_launch_app_desc">यो उपकरण जडान हुँदा एपहरू खोल्नुहोस्।</string>
    <string name="devices_device_config_launch_app_multiple_desc">%d एपहरू चयन गरिए</string>
    <string name="devices_device_config_show_home_screen_label">होम स्क्रिन देखाउनुहोस्</string>
    <string name="devices_device_config_show_home_screen_desc">यस उपकरणका सबै घटनाहरू प्रशोधन भइसकेपछि, होम स्क्रिन देखाउने प्रयास गर्नुहोस्। यो सबै Android संस्करणहरूमा काम नगर्न सक्छ।</string>
    <string name="devices_device_config_nudge_volume_label">भोल्युम हल्काउनुहोस्</string>
    <string name="devices_device_config_nudge_volume_description">भोल्युमलाई एक वृद्धिले घटाउनुहोस् त्यसपछि बढाउनुहोस्, भले पनि वाञ्छित भोल्युम पहिले नै सेट गरिएको छ (प्रणाली अनुसार)।</string>
    <string name="devices_device_config_visible_adjustments_label">दृश्यमान समायोजनहरू</string>
    <string name="devices_device_config_visible_adjustments_desc">यस एपले यस उपकरणका लागि समायोजन गर्दा प्रणालीको भोल्युम विन्डो देखाउनुहोस्।</string>
    <string name="devices_device_config_keep_awake_label">जागा राख्नुहोस्</string>
    <string name="devices_device_config_keep_awake_desc">जडान भएको बेला उपकरणलाई जागा राख्ने प्रयास गर्नुहोस्। Android संस्करणमा निर्भर गर्दै व्यवहार फरक हुन सक्छ।</string>
    <string name="devices_device_config_volume_observe_label">परिवर्तनहरू अवलोकन गर्नुहोस्</string>
    <string name="devices_device_config_volume_observe_desc">यो उपकरण जडान भएको बेला सक्रिय रहनुहोस् र यस एपले नगराएका भोल्युम परिवर्तनहरू सुरक्षित गर्नुहोस्।</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">विच्छेद हुँदा भोल्युम सुरक्षित गर्नुहोस्</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">यो उपकरण विच्छेद हुँदा हालको भोल्युम स्तरहरू कैद गरी सुरक्षित गर्नुहोस्।</string>
    <string name="devices_device_config_volume_save_on_disconnect_hint">केही यन्त्रहरूमा, प्रणालीले हामीले भोल्युम पढ्न सक्नु अघि नै अडियो राउटिङ बदल्छ। यदि सुरक्षित गरिएका मानहरू तपाईंले सेट गर्नुभएको कुरासँग मेल खाँदैन भने, यसको सट्टा \"भोल्युम परिवर्तनहरू अवलोकन गर्नुहोस्\" सक्षम गर्ने प्रयास गर्नुहोस्।</string>
    <string name="devices_device_config_volume_lock_label">भोल्युम लक</string>
    <string name="devices_device_config_volume_lock_desc">यो उपकरण जडान भएको बेला यस एपबाट नगरिएका कुनै पनि भोल्युम परिवर्तनहरू फिर्ता हुनेछन्।</string>
    <string name="devices_device_config_volume_lock_override_desc">भोल्युम लक हाल यो सुविधालाई ओभरराइड गर्दैछ।</string>
    <string name="devices_device_config_volume_rate_limiter_label">भोल्युम दर सीमक</string>
    <string name="devices_device_config_volume_rate_limiter_desc">द्रुत वा अत्यधिक भोल्युम समायोजनलाई रोक्नको लागि भोल्युम परिवर्तनको आवृत्ति सीमित गर्नुहोस्।</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_label">भोल्युम वृद्धि विलम्ब</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_desc">भोल्युम वृद्धिबिचको न्यूनतम समय: %d ms</string>
    <string name="devices_device_config_volume_rate_limit_decrease_duration_label">भोल्युम कमी विलम्ब</string>
