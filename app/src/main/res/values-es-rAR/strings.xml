    <string name="devices_device_config_show_home_screen_label">Mostrar pantalla de inicio</string>
    <string name="devices_device_config_show_home_screen_desc">Después de procesar todos los eventos de este dispositivo, intenta mostrar la pantalla de inicio. Puede que no funcione en todas las versiones de Android.</string>
    <string name="devices_device_config_nudge_volume_label">Ajustar volumen</string>
    <string name="devices_device_config_nudge_volume_description">Baja y luego sube el volumen un incremento, incluso si el volumen deseado ya está establecido (según el sistema).</string>
    <string name="devices_device_config_visible_adjustments_label">Ajustes visibles</string>
    <string name="devices_device_config_visible_adjustments_desc">Muestra la ventana de volumen del sistema mientras esta app realiza ajustes para este dispositivo.</string>
    <string name="devices_device_config_keep_awake_label">Mantener activo</string>
    <string name="devices_device_config_keep_awake_desc">Intenta mantener el dispositivo activo mientras esté conectado. El comportamiento puede variar según la versión de Android.</string>
    <string name="devices_device_config_volume_observe_label">Observar cambios</string>
    <string name="devices_device_config_volume_observe_desc">Permanece activo mientras este dispositivo esté conectado y guarda los cambios de volumen que no hayan sido realizados por esta app.</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">Guardar volumen al desconectar</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">Captura y guarda los niveles de volumen actuales cuando este dispositivo se desconecta.</string>
    <string name="devices_device_config_volume_save_on_disconnect_hint">En algunos dispositivos, el sistema cambia el enrutamiento de audio antes de que podamos leer los volúmenes. Si los valores guardados no coinciden con lo que habías configurado, probá activar \"Observar cambios de volumen\" en su lugar.</string>
