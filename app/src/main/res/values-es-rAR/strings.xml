    <string name="devices_device_config_monitoring_duration_desc">Duración en milisegundos, tras realizar ajustes, durante la cual se bloquearán cambios de volumen adicionales.</string>
    <string name="devices_device_config_adjustment_delay_label">Retraso de ajuste</string>
    <string name="devices_device_config_adjustment_delay_desc">El retraso en milisegundos entre cada ajuste de volumen. Un retraso de 0 ms significa que el volumen se establece instantáneamente cuando este dispositivo se conecta.</string>
    <string name="devices_device_config_reaction_delay_label">Retraso de reacción</string>
    <string name="devices_device_config_reaction_delay_desc">El retraso en milisegundos hasta que esta app reacciona a este dispositivo.</string>
