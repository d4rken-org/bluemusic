    <string name="devices_device_config_section_timing_label">Временско подешавање</string>
    <string name="devices_device_config_monitoring_duration_label">Трајање надзора</string>
    <string name="devices_device_config_monitoring_duration_desc">Трајање у милисекундама, након што су подешавања направљена, током ког ће свака даља промена јачине звука бити блокирана.</string>
    <string name="devices_device_config_adjustment_delay_label">Кашњење подешавања</string>
    <string name="devices_device_config_adjustment_delay_desc">Кашњење у милисекундама између сваког подешавања јачине звука. Кашњење 0ms значи тренутно постављање јачине звука кад се овај уређај повеже.</string>
    <string name="devices_device_config_reaction_delay_label">Кашњење реакције</string>
    <string name="devices_device_config_reaction_delay_desc">Кашњење у милисекундама пре него што апликација реагује на овај уређај.</string>
    <string name="devices_device_config_section_reaction_label">Реакција</string>
    <string name="devices_device_config_launch_app_label">Покрени апликације</string>
    <string name="devices_device_config_launch_app_desc">Покрече апликације кад се овај уређај повеже.</string>
    <string name="devices_device_config_launch_app_multiple_desc">%d апликација изабрано</string>
    <string name="devices_device_config_show_home_screen_label">Прикажи почетни екран</string>
    <string name="devices_device_config_show_home_screen_desc">Након што су сви догађаји обрађени за овај уређај, покуша приказати почетни екран. Ово можда неће радити на свим верзијама Андроида.</string>
    <string name="devices_device_config_nudge_volume_label">Подешавање јачине</string>
    <string name="devices_device_config_nudge_volume_description">Спусти па подигни јачину звука за један корак, чак и ако је жељена јачина звука већ постављена (према систему).</string>
    <string name="devices_device_config_visible_adjustments_label">Видљива подешавања</string>
    <string name="devices_device_config_visible_adjustments_desc">Прикажи системски прозор јачине звука док ова апликација врши подешавања за овај уређај.</string>
    <string name="devices_device_config_keep_awake_label">Одржи буђним</string>
    <string name="devices_device_config_keep_awake_desc">Покуша да одржи уређај будним док је повезан. Понашање може да варира у зависности од верзије Андроида.</string>
    <string name="devices_device_config_volume_observe_label">Прати промене</string>
    <string name="devices_device_config_volume_observe_desc">Остај активан док је овај уређај повезан и сачувај промене јачине звука које нису направљене овом апликацијом.</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">Сачувај јачину при искључивању</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">Сними и сачувај тренутне нивое јачине звука кад се овај уређај искључи.</string>
    <string name="devices_device_config_volume_save_on_disconnect_hint">На неким уређајима систем мења аудио рутирање пре него што успемо да очитамо јачину звука. Ако сачуване вредности не одговарају ономе што сте поставили, покушајте да уместо тога омогућите „Посматрај промене јачине звука“.</string>
    <string name="devices_device_config_volume_lock_label">Закључавање јачине</string>
    <string name="devices_device_config_volume_lock_desc">Све промене јачине звука направљене ван ове апликације биће враћене док је овај уређај повезан.</string>
    <string name="devices_device_config_volume_lock_override_desc">Закључавање јачине звука тренутно замењује ову функцију.</string>
    <string name="devices_device_config_volume_rate_limiter_label">Ограничавач брзине јачине</string>
    <string name="devices_device_config_volume_rate_limiter_desc">Ограничи учесталост промена јачине звука да би се спречили брзи или прекомерни прелази јачине.</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_label">Кашњење повећања јачине</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_desc">Минимално време између повећања јачине: %d ms</string>
    <string name="devices_device_config_volume_rate_limit_decrease_duration_label">Кашњење смањивања јачине</string>
