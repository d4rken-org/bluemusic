    <string name="devices_device_config_monitoring_duration_label">Продължителност на наблюдение</string>
    <string name="devices_device_config_monitoring_duration_desc">Продължителност в милисекунди, след като са направени настройки, по време на която всякакви допълнителни промени в силата на звука ще бъдат блокирани.</string>
    <string name="devices_device_config_adjustment_delay_label">Настройка на закъснението</string>
    <string name="devices_device_config_adjustment_delay_desc">Закъснението в милисекунди между всяка настройка. Закъснение 0ms означава незабавна настройка на силата на звука, когато това устройство се свързва.</string>
    <string name="devices_device_config_reaction_delay_label">Забавяне на реакцията</string>
    <string name="devices_device_config_reaction_delay_desc">Закъснението в милисекунди докато приложението реагира на това устройство.</string>
    <string name="devices_device_config_section_reaction_label">Други</string>
    <string name="devices_device_config_launch_app_label">Стартирай приложение</string>
    <string name="devices_device_config_launch_app_desc">Стартиране на приложение, когато това устройство се свързва.</string>
    <string name="devices_device_config_launch_app_multiple_desc">%d приложения избрани</string>
    <string name="devices_device_config_show_home_screen_label">Покажи началния екран</string>
    <string name="devices_device_config_show_home_screen_desc">След обработката на всички събития за това устройство, опитай да покажеш началния екран. Може да не работи на всички версии на Android.</string>
    <string name="devices_device_config_nudge_volume_label">Бутни силата на звука</string>
    <string name="devices_device_config_nudge_volume_description">Намали след това увеличи силата на звука с едно стъпало, дори ако желаната стойност вече е зададена (според системата).</string>
    <string name="devices_device_config_visible_adjustments_label">Видими настройки</string>
    <string name="devices_device_config_visible_adjustments_desc">Показвай системния прозорец за звука, докато приложението регулира звука за това устройство.</string>
    <string name="devices_device_config_keep_awake_label">Остани буден</string>
    <string name="devices_device_config_keep_awake_desc">Опитва се да поддържа устройството будно докато е свързано. Поведението може да се различава в зависимост от версията на Android.</string>
    <string name="devices_device_config_volume_observe_label">Наблюдавай промените</string>
    <string name="devices_device_config_volume_observe_desc">Остани активен докато устройството е свързано и запазвай промените в силата на звука, които не са причинени от това приложение.</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">Запази силата на звука при изключване</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">Запазва текущите нива на звука при прекъсване на връзката с това устройство.</string>
    <string name="devices_device_config_volume_lock_label">Заключване на звука</string>
    <string name="devices_device_config_volume_lock_desc">Всякакви промени в силата на звука, направени извън приложението, ще бъдат отменени докато устройството е свързано.</string>
    <string name="devices_device_config_volume_rate_limiter_label">Ограничител на честотата на силата на звука</string>
    <string name="devices_device_config_volume_rate_limiter_desc">Ограничава честотата на промените в силата на звука, за да се предотврати бързо или прекомерно регулиране.</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_label">Забавяне на увеличението на силата на звука</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_desc">Минимално време между увеличенията на силата на звука: %d мс</string>
    <string name="devices_device_config_volume_rate_limit_decrease_duration_label">Забавяне на намаляването на силата на звука</string>
