    <!-- Onboarding-->
    <string name="onboarding_welcome_title">Добре дошли в BVM</string>
    <string name="onboarding_welcome_message">Bluetooth Volume Manager ти позволява автоматично да управляваш силата на звука на Bluetooth устройствата.</string>
    <string name="onboarding_welcome_action">Да тръгваме</string>
    <string name="onboarding_beta_title">Бета версия</string>
    <string name="onboarding_beta_message">Това е бета (тестова) версия. Продължи с чувство за хумор и резервен план. Моля, докладвай проблемите, на които се натъкнеш.</string>
    <string name="onboarding_beta_action">От нищо не се страхувам</string>
    <string name="onboarding_privacy_title">Поверителност &amp; данни</string>
    <string name="onboarding_privacy_message">Bluetooth Volume Manager няма реклами и не продава потребителски данни (дори е с отворен код). Поверителността ти е важна за мен.</string>
    <string name="onboarding_privacy_read_action">Прочети политиката за поверителност</string>
    <string name="onboarding_privacy_action">Приеми</string>
    <string name="onboarding_rewrite_title">Приложението е обновено</string>
    <string name="onboarding_rewrite_message">Трябваше да пренапиша приложението, за да следвам промените в Android и изискванията на Google. Модернизирах го там, където беше възможно, за да продължи да работи надеждно.</string>
    <string name="onboarding_rewrite_features">Някои функции са се променили по време на актуализацията. Моля, провери настройките на устройствата си, за да се увериш, че всичко е конфигурирано правилно.</string>
    <string name="onboarding_rewrite_action">Продължи</string>
