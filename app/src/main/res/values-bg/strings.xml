    <string name="devices_device_config_notification_volume_label">Звук на известия</string>
    <string name="devices_device_config_notification_volume_desc">Не всички устройства поддържат отделна настройка за силата на звука на известията. Може да зададе и тих или вибрационен режим.</string>
