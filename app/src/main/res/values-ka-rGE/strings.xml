    <string name="onboarding_privacy_title">კონფიდენციალურობა და მონაცემები</string>
    <string name="onboarding_privacy_message">Bluetooth Volume Manager-ს არ აქვს რეკლამები და არ ყიდის მომხმარებლის მონაცემებს (ის კიდევ ღია კოდიანია). თქვენი კონფიდენციალურობა ჩემთვის მნიშვნელოვანია.</string>
    <string name="onboarding_privacy_read_action">კონფიდენციალურობის პოლიტიკის წაკითხვა</string>
    <string name="onboarding_privacy_action">მიღება</string>
    <string name="onboarding_rewrite_title">აპი განახლდა</string>
    <string name="onboarding_rewrite_message">მომიწია აპის გადაწერა Android-ის ცვლილებებისა და Google-ის მოთხოვნების გასაცნობად. გავახლე აპი სადაც შესაძლებელი იყო, რათა განაგრძოს სანდო მუშაობა.</string>
    <string name="onboarding_rewrite_features">განახლების დროს ზოგიერთი ფუნქცია შეიცვალა. გთხოვთ შეამოწმოთ მოწყობილობის პარამეტრები, რათა დარწმუნდეთ, რომ ყველაფერი სწორად არის კონფიგურირებული.</string>
    <string name="onboarding_rewrite_action">გაგრძელება</string>
