    <string name="devices_device_config_show_home_screen_label">Башкы экранды көрсөтүү</string>
    <string name="devices_device_config_show_home_screen_desc">Бул түзмөк үчүн бардык иш-чаралар иштетилгенден кийин, башкы экранды көрсөтүүгө аракет кылыңыз. Бул Android\'дин бардык версияларында иштебеши мүмкүн.</string>
    <string name="devices_device_config_nudge_volume_label">Үндү жылжытуу</string>
    <string name="devices_device_config_nudge_volume_description">Каалган үн деңгээли системага ылайык буга чейин орнотулган болсо да, үндү бир кадамга төмөндөтүп, андан кийин жогорулатыңыз.</string>
    <string name="devices_device_config_visible_adjustments_label">Көрүнүктүү тууралоолор</string>
    <string name="devices_device_config_visible_adjustments_desc">Бул колдонмо бул түзмөк үчүн тууралоолор жасап жатканда системанын үн терезесин көрсөтүүгө.</string>
    <string name="devices_device_config_keep_awake_label">Ойгонуп туруу</string>
    <string name="devices_device_config_keep_awake_desc">Туташып турганда түзмөктү ойгонуп турууга аракет кылыңыз. Жүрүм-туруму Android версиясына жараша айырмаланышы мүмкүн.</string>
    <string name="devices_device_config_volume_observe_label">Өзгөрүүлөрдү байкоо</string>
    <string name="devices_device_config_volume_observe_desc">Бул түзмөк туташып турганда активдүү болуп, бул колдонмо жасабаган үн өзгөртүүлөрүн сактаңыз.</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">Ажыратылганда үндү сактоо</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">Бул түзмөк ажыратылганда учурдагы үн деңгээлдерин тартып алып сактоо.</string>
    <string name="devices_device_config_volume_save_on_disconnect_hint">Кээ бир түзмөктөрдө, система үн маршрутизациясын биз үндүктүн деңгээлин окуй алганга чейин которуп салат. Эгер сакталган маанилер сиз коюп кеткен маанилерге дал келбесе, анын ордуна \"Үн өзгөрүүлөрүн байкоо\" функциясын иштетип көрүңүз.</string>
    <string name="devices_device_config_volume_lock_label">Үн кулпусу</string>
    <string name="devices_device_config_volume_lock_desc">Бул колдонмо аркылуу менен жасалбаган үн өзгөртүүлөрү бул түзмөк туташып турганда кайтарылып берилет.</string>
    <string name="devices_device_config_volume_lock_override_desc">Үн кулпусу азыр бул функцияны жокко чыгарат.</string>
    <string name="devices_device_config_volume_rate_limiter_label">Үн ылдамдыгын чектөүчү</string>
    <string name="devices_device_config_volume_rate_limiter_desc">Тез же ашыкча үн тууралоолорунун алдын алуу үчүн үн өзгөртүүлөрүнүн жыштыгын чектөүү.</string>
