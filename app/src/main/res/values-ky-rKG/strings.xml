    <string name="devices_device_config_monitoring_duration_label">Мониторинг убактысы</string>
    <string name="devices_device_config_monitoring_duration_desc">Тууралоолар жасалгандан кийин, кийинки үн өзгөртүүлөрү бөгөттөлө турган миллисекунддардагы убакыт.</string>
    <string name="devices_device_config_adjustment_delay_label">Тууралоо кечиктирүүсү</string>
    <string name="devices_device_config_adjustment_delay_desc">Ар бир үн тууралоосунун ортосундагы миллисекунддардагы кечиктирүү. 0 мс кечиктирүү бул түзмөк туташканда үндү дароо орнотуу дегенди билдирет.</string>
    <string name="devices_device_config_reaction_delay_label">Жооп берүү кечиктирүүсү</string>
    <string name="devices_device_config_reaction_delay_desc">Бул колдонмо бул түзмөккө жооп бермейинче миллисекунддардагы кечиктирүү.</string>
    <string name="devices_device_config_section_reaction_label">Жооп берүү</string>
    <string name="devices_device_config_launch_app_label">Колдонмолорду ишке киргизүү</string>
