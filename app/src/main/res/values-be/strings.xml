    <string name="devices_device_config_remove_device_label">Забыць прыладу</string>
    <string name="devices_device_config_remove_device_desc">Выдаляе прыладу з гэтага дадатку і выдаляе яе канфігурацыю. Гэта не разʼядноўвае прыладу.</string>
    <string name="devices_device_config_remove_device_action">Забыць</string>
    <string name="devices_device_config_remove_device_confirmation">Забыць %s з кіраваных прылад?</string>
    <string name="devices_device_config_rename_device_label">Перайменаваць прыладу</string>
    <string name="devices_device_config_rename_device_desc">Перайменавайце гэту прыладу ў гэтым дадатку і, калі магчыма, ў сістэме.</string>
    <string name="devices_device_config_rename_device_action">Перайменаваць</string>
    <string name="devices_device_config_enabled_label">Уключана</string>
    <string name="devices_device_config_enabled_desc">Рэагаваць на гэту прыладу пры падключэнні</string>
    <string name="devices_device_config_section_timing_label">Час</string>
    <string name="devices_device_config_monitoring_duration_label">Працягласць маніторынгу</string>
    <string name="devices_device_config_monitoring_duration_desc">Працягласць у мілісекундах пасля выкананых рэгулёвак, на працягу якой любыя далейшыя змены гучнасці будуць заблакіраваны.</string>
    <string name="devices_device_config_adjustment_delay_label">Затрымка рэгулёўкі</string>
    <string name="devices_device_config_adjustment_delay_desc">Затрымка ў мілісекундах паміж кожнай рэгулёўкай гучнасці. Затрымка 0мс азначае імгненную ўстаноўку гучнасці пры падключэнні гэтай прылады.</string>
    <string name="devices_device_config_reaction_delay_label">Затрымка рэакцыі</string>
    <string name="devices_device_config_reaction_delay_desc">Затрымка ў мілісекундах да рэакцыі гэтага дадатку на гэту прыладу.</string>
    <string name="devices_device_config_section_reaction_label">Рэакцыя</string>
    <string name="devices_device_config_launch_app_label">Запускаць дадаткі</string>
    <string name="devices_device_config_launch_app_desc">Запускаць дадаткі пры падключэнні гэтай прылады.</string>
    <string name="devices_device_config_launch_app_multiple_desc">Выбрана %d дадаткаў</string>
    <string name="devices_device_config_show_home_screen_label">Паказаць галоўны экран</string>
    <string name="devices_device_config_show_home_screen_desc">Пасля апрацоўкі ўсіх падзей для гэтай прылады паспрабаваць паказаць галоўны экран. Гэта можа не працаваць на ўсіх версіях Android.</string>
    <string name="devices_device_config_nudge_volume_label">Падштурхнуць гучнасць</string>
    <string name="devices_device_config_nudge_volume_description">Знізіць, а потым павысіць гучнасць на адзін крок, нават калі патрэбная гучнасць ўжо ўстаноўлена (паводле сістэмы).</string>
    <string name="devices_device_config_visible_adjustments_label">Бачныя рэгулёўкі</string>
    <string name="devices_device_config_visible_adjustments_desc">Паказваць акно гучнасці сістэмы, пакуль гэты дадатак рэгуліруе гучнасць для гэтай прылады.</string>
    <string name="devices_device_config_keep_awake_label">Не даваць засыпаць</string>
    <string name="devices_device_config_keep_awake_desc">Паспрабаваць ўтрымліваць прыладу актыўнай пад час падключэння. Паводзіны могуць адрознівацьца ў залежнасці ад версіі Android.</string>
    <string name="devices_device_config_volume_observe_label">Назіраць за зменамі</string>
    <string name="devices_device_config_volume_observe_desc">Заставацौца актыўным, пакуль гэта прылада падключана, і захоўваць змены гучнасці, якія не зробленыя гэтым дадаткам.</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">Захаваць гучнасць пры адключэнні</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">Зафіксаваць і захоўваць бягучыя ўзроўні гучнасці пры адключэнні гэтай прылады.</string>
    <string name="devices_device_config_volume_save_on_disconnect_hint">На некаторых прыладах сістэма перамыкае аўдыёмаршрутызацыю да таго, як мы можам прачытаць гучнасць. Калі захаваныя значэнні не адпавядаюць таму, што вы ўсталявалі, паспрабуйце ўключыць «Сачыць за змяненнямі гучнасці».</string>
    <string name="devices_device_config_volume_lock_label">Блакіроўка гучнасці</string>
    <string name="devices_device_config_volume_lock_desc">Любыя змены гучнасці, зробленыя не чараз гэты дадатак, будуць адменены, пакуль гэта прылада падключана.</string>
    <string name="devices_device_config_volume_lock_override_desc">Блакіроўка гучнасці цяпер перавызначае гэтую функцыю.</string>
    <string name="devices_device_config_volume_rate_limiter_label">Абмяжальнік частаты змены гучнасці</string>
    <string name="devices_device_config_volume_rate_limiter_desc">Абмяжыць частату змен гучнасці для прадухілення хуткіх або надмерных рэгулёвак.</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_label">Затрымка павышэння гучнасці</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_desc">Мінімальны час паміж павышэннямі гучнасці: %d мс</string>
    <string name="devices_device_config_volume_rate_limit_decrease_duration_label">Затрымка зніжэння гучнасці</string>
    <string name="devices_device_config_volume_rate_limit_decrease_duration_desc">Мінімальны час паміж зніжэннямі гучнасці: %d мс</string>
    <string name="devices_device_config_autoplay_label">Аўтазапуск</string>
    <string name="devices_device_config_autoplay_desc">Сімуляваць націск кнопкі адтварэння на пульце Bluetooth пры падключэнні гэтай прылады.</string>
    <string name="devices_device_config_autoplay_keycodes_title">Тыпы клавіш аўтазапуску</string>
    <string name="devices_device_config_autoplay_keycodes_available">Даступныя тыпы клавіш</string>
    <string name="devices_device_config_autoplay_keycodes_order">Выбраныя клавішы (па парадку)</string>
    <string name="devices_device_config_autoplay_keycodes_label">Тыпы клавіш</string>
    <string name="devices_device_config_autoplay_keycodes_desc">Наладзіць, якія клавішы адпраўляць і ў якім парадку</string>
    <string name="devices_device_config_autoplay_keycodes_none_set">Клавішы не наладжаны</string>
