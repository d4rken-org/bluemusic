    <string name="devices_device_config_alarm_volume_label">Гучнасць будзільніка</string>
    <string name="devices_device_config_alarm_volume_desc">Некаторыя дадаткі будзільніка замест гэтага выкарыстоўваюць гучнасць музыкі.</string>
    <string name="devices_device_config_notification_volume_label">Гучнасць апавяшчэнняў</string>
    <string name="devices_device_config_notification_volume_desc">Не ўсе прылады падтрымліваюць асобную наладу гучнасці апавяшчэнняў. Таксама можна ўсталяваць рэжым цішыні або вібрацыі.</string>
    <string name="devices_device_config_music_volume_label">Гучнасць музыкі</string>
    <string name="devices_device_config_music_volume_desc">Кіраваць гучнасцю, якая ўплывае на музыку і гульні пры падключэнні гэтай прылады.</string>
    <string name="devices_device_config_call_volume_label">Гучнасць выкліку</string>
    <string name="devices_device_config_call_volume_desc">Кіраваць гучнасцю, якая ўплывае на выклікі пры падключэнні гэтай прылады.</string>
    <string name="devices_device_config_ring_volume_label">Гучнасць звонку</string>
    <string name="devices_device_config_ring_volume_desc">Кіраваць гучнасцю, якая ўплывае на мелодыю выкліку. Таксама можна ўсталяваць рэжым цішыні або вібрацыі.</string>
    <string name="devices_device_config_notification_policy_required_ringtone">Кіраванне гучнасцю звонку патрабуе доступу да палітыкі апавяшчэнняў</string>
    <string name="devices_device_config_notification_policy_required_notification">Кіраванне гучнасцю апавяшчэнняў патрабуе доступу да палітыкі апавяшчэнняў</string>
    <string name="devices_device_config_notification_policy_required_dnd">Кіраванне рэжымам \"Не турбаваць\" патрабуе доступу да палітыкі апавяшчэнняў</string>
    <string name="devices_device_config_notification_policy_action">Даць доступ</string>
