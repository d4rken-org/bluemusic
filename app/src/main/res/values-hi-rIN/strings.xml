    <string name="devices_device_config_remove_device_label">डिवाइस भूल जाएं</string>
    <string name="devices_device_config_remove_device_desc">इस ऐप से डिवाइस को भूल जाता है और इसका कॉन्फिगरेशन डिलीट कर देता है। यह डिवाइस को अनपेयर नहीं करता।</string>
    <string name="devices_device_config_remove_device_action">भूल जाएं</string>
    <string name="devices_device_config_remove_device_confirmation">प्रबंधित डिवाइस से %s को भूल जाएं?</string>
    <string name="devices_device_config_rename_device_label">डिवाइस का नाम बदलें</string>
    <string name="devices_device_config_rename_device_desc">इस ऐप में इस डिवाइस का नाम बदलें, और यदि संभव हो तो सिस्टम में भी।</string>
    <string name="devices_device_config_rename_device_action">नाम बदलें</string>
    <string name="devices_device_config_enabled_label">सक्षम</string>
    <string name="devices_device_config_enabled_desc">कनेक्ट होने पर इस डिवाइस पर प्रतिक्रिया करें</string>
    <string name="devices_device_config_section_timing_label">समय</string>
    <string name="devices_device_config_monitoring_duration_label">निगरानी की अवधि</string>
    <string name="devices_device_config_monitoring_duration_desc">मिलिसेकंड में एक अवधि, समायोजन के बाद की गई है, जिसके दौरान किसी भी आगे की मात्रा में परिवर्तन अवरुद्ध हो जाएगा।</string>
    <string name="devices_device_config_adjustment_delay_label">समायोजन विलंब</string>
    <string name="devices_device_config_adjustment_delay_desc">प्रत्येक वॉल्यूम समायोजन के बीच मिलीसेकंड में देरी। देरी 0ms का मतलब है कि यह डिवाइस जुड़ने पर तुरंत वॉल्यूम सेट कर रहा है।</string>
    <string name="devices_device_config_reaction_delay_label">विलंब प्रक्रिया</string>
    <string name="devices_device_config_reaction_delay_desc">जब तक यह ऐप्प इस डिवाइस पर प्रतिक्रिया न करे तब तक कुछ सेकंड का विलंब करे</string>
    <string name="devices_device_config_section_reaction_label">अन्य</string>
    <string name="devices_device_config_launch_app_label">एप्प प्रारम्भ करें</string>
    <string name="devices_device_config_launch_app_desc">जब यह डिवाइस कनेक्ट हो तब ऐप प्रारम्भ करें।</string>
    <string name="devices_device_config_launch_app_multiple_desc">%d ऐप्स चयनित</string>
    <string name="devices_device_config_show_home_screen_label">होम स्क्रीन दिखाएं</string>
    <string name="devices_device_config_show_home_screen_desc">इस डिवाइस के सभी इवेंट प्रोसेस होने के बाद, होम स्क्रीन दिखाने की कोशिश करें। यह सभी Android वर्जन पर काम नहीं कर सकता।</string>
    <string name="devices_device_config_nudge_volume_label">वॉल्यूम को राम दें</string>
    <string name="devices_device_config_nudge_volume_description">पहले वॉल्यूम कॉ कम करें फिर एक स्तर बढ़ाएं, भले ही वांछित वॉल्यूम पहले से सेट हो (सिस्टम के अनुसार)।</string>
    <string name="devices_device_config_visible_adjustments_label">दृश्य समायोजन</string>
    <string name="devices_device_config_visible_adjustments_desc">डिवाइस कार्ड पर कौन से समायोजन दिखाए जाएं, इसे टॉगल करें</string>
    <string name="devices_device_config_keep_awake_label">स्क्रीन चालू रखें</string>
    <string name="devices_device_config_keep_awake_desc">इस उपकरण के कनेक्ट होने के दौरान स्क्रीन को चालू रखें</string>
    <string name="devices_device_config_volume_observe_label">परिवर्तन देखें</string>
    <string name="devices_device_config_volume_observe_desc">जब यह डिवाइस जुड़ा हो तो सक्रिय रहें और उन वॉल्यूम परिवर्तनों को सेव करें जो इस ऐप के कारण नहीं हुए हैं।</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">डिस्कनेक्ट पर वॉल्यूम सेव करें</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">इस डिवाइस के डिस्कनेक्ट होने पर वर्तमान वॉल्यूम स्तर कैप्चर करें और सेव करें।</string>
    <string name="devices_device_config_volume_save_on_disconnect_hint">कुछ डिवाइस पर, सिस्टम ऑडियो रूटिंग बदल देता है इससे पहले कि हम वॉल्यूम पढ़ सकें। अगर सेव की गई वैल्यू वो नहीं है जो आपने सेट की थी, तो इसके बजाय \"वॉल्यूम परिवर्तन देखें\" को सक्षम करने का प्रयास करें।</string>
    <string name="devices_device_config_volume_lock_label">वॉल्यूम लॉक</string>
    <string name="devices_device_config_volume_lock_desc">इस उपकरण के माध्यम से नहीं किए गए किसी भी मात्रा परिवर्तन को वापस कर दिया जाएगा, जबकि यह उपकरण जुड़ा हुआ है।</string>
    <string name="devices_device_config_volume_lock_override_desc">वॉल्यूम लॉक अभी इस सुविधा को ओवरराइड कर रहा है।</string>
    <string name="devices_device_config_volume_rate_limiter_label">वॉल्यूम दर सीमक</string>
    <string name="devices_device_config_volume_rate_limiter_desc">वॉल्यूम परिवर्तनों की आवृत्ति को सीमित करें ताकि तेज़ या अत्यधिक वॉल्यूम समायोजन को रोका जा सके।</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_label">वॉल्यूम बढ़ाने में देरी</string>
    <string name="devices_device_config_volume_rate_limit_increase_duration_desc">वॉल्यूम बढ़ाने के बीच न्यूनतम समय: %d ms</string>
