    <string name="devices_device_config_notification_policy_required_ringtone">रिंग वॉल्यूम नियंत्रण के लिए नोटिफिकेशन पॉलिसी एक्सेस की आवश्यकता</string>
    <string name="devices_device_config_notification_policy_required_notification">नोटिफिकेशन वॉल्यूम नियंत्रण के लिए नोटिफिकेशन पॉलिसी एक्सेस की आवश्यकता</string>
