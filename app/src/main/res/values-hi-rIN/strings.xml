    <string name="onboarding_welcome_title">BVM में आपका स्वागत है</string>
    <string name="onboarding_welcome_message">ब्लूटूथ वॉल्यूम मैनेजर आपको ब्लूटूथ डिवाइस के वॉल्यूम को स्वचालित रूप से प्रबंधित करने की सुविधा देता है।</string>
    <string name="onboarding_welcome_action">चलिए शुरू करते हैं</string>
    <string name="onboarding_beta_title">बीटा संस्करण</string>
    <string name="onboarding_beta_message">यह एक बीटा (परीक्षण) बिल्ड है। हास की भावना और एक बैकअप योजना के साथ आगे बढ़ें। कृपया आपको आने वाली समस्याओं की रिपोर्ट करें।</string>
    <string name="onboarding_beta_action">मुझे किसी बात का डर नहीं</string>
    <string name="onboarding_privacy_title">गोपनीयता और डेटा</string>
    <string name="onboarding_privacy_message">ब्लूटूथ वॉल्यूम मैनेजर में कोई विज्ञापन नहीं हैं और यह यूजर डेटा नहीं बेचता (यह ओपन-सोर्स भी है)। आपकी गोपनीयता मेरे लिए महत्वपूर्ण है।</string>
    <string name="onboarding_privacy_read_action">प्राइवेसी पॉलिसी पढ़ें</string>
    <string name="onboarding_privacy_action">स्वीकार करें</string>
    <string name="onboarding_rewrite_title">ऐप को नया रूप दिया गया!</string>
    <string name="onboarding_rewrite_message">मैंने एंड्रॉइड में होने वाले बदलाव और गूगल की आवश्यकताओं के कारण ब्लूटूथ वॉल्यूम मैनेजर को सफर से पूरी तरह से पुनर्निर्मित किया है ताकि ऐप विश्वसनीय तरीके से काम करता रहे।</string>
    <string name="onboarding_rewrite_features">इस अपडेट के दौरान कुछ डिवाइस सेटिंग्स रीसेट हो गई होंगी। कृपया अपने डिवाइस कॉन्फिगरेशन की जांच करें।</string>
    <string name="onboarding_rewrite_action">जारी रखें</string>
