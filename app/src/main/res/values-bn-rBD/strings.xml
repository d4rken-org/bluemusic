    <string name="devices_device_config_keep_awake_label">জেগে রাখুন</string>
    <string name="devices_device_config_keep_awake_desc">সংযুক্ত থাকার সময় ডিভাইস জেগে রাখার চেষ্টা করুন। Android সংস্করণভেদে আচরণ ভিন্ন হতে পারে।</string>
