    <string name="onboarding_welcome_message">Bluetooth Volume Manager আপনাকে স্বয়ংক্রিয়ভাবে ব্লুটুথ ডিভাইসের ভলিউম পরিচালনা করতে দেয়।</string>
    <string name="onboarding_welcome_action">চলুন শুরু করি</string>
    <string name="onboarding_beta_title">বেটা সংস্করণ</string>
    <string name="onboarding_beta_message">এটি একটি বিটা (পরীক্ষা করার) বিল্ড। নিজের চিন্তা ভাবনা ব্যবহার করে এবং একটি ব্যাকআপ পরিকল্পনা রেখে শুরু করুন। আপনি যে সমস্যার সম্মুখীন হবেন সেগুলি রিপোর্ট করুন।</string>
    <string name="onboarding_beta_action">আমি কিছু ভয় পাই না</string>
    <string name="onboarding_privacy_title">গোপনীয়তা ও তথ্য</string>
    <string name="onboarding_privacy_message">Bluetooth Volume Manager-এ কোনো বিজ্ঞাপন নেই এবং এটি ব্যবহারকারীর তথ্য বিক্রি করে না (এটি এমনকি ওপেন-সোর্স)। আপনার গোপনীয়তা আমার কাছে গুরুত্বপূর্ণ।</string>
    <string name="onboarding_privacy_read_action">গোপনীয়তা নীতি পড়ুন</string>
    <string name="onboarding_privacy_action">গ্রহণ করুন</string>
    <string name="onboarding_rewrite_title">অ্যাপ আধুনিকীকরণ</string>
    <string name="onboarding_rewrite_message">আন্ড্রয়েডের পরিবর্তন এবং গুগলের প্রয়োজনীয়তার সাথে তাল রাখতে আমাকে অ্যাপটি পুনরায় লিখতে হয়েছিল। যতটা সম্ভব অ্যাপটি আধুনিক করেছি যাতে এটি নিভরযোগ্যভাবে কাজ করতে থাকে।</string>
    <string name="onboarding_rewrite_features">আপডেটের সময় কিছু ফিচার বদলে গেছে। সবকিছু সঠিকভাবে কনফিগার করা আছে কিনা তা নিশ্চিত করতে আপনার ডিভাইস সেটিংস দেখুন।</string>
    <string name="onboarding_rewrite_action">চালিয়ে যান</string>
