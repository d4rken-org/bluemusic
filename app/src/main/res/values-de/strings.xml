    <string name="devices_device_config_launch_app_multiple_desc">%d Apps ausgewählt</string>
    <string name="devices_device_config_show_home_screen_label">Startbildschirm anzeigen</string>
    <string name="devices_device_config_show_home_screen_desc">Nachdem alle Ereignisse für dieses Gerät verarbeitet wurden, versuche den Startbildschirm anzuzeigen. Das funktioniert möglicherweise nicht auf allen Android-Versionen.</string>
    <string name="devices_device_config_nudge_volume_label">Lautstärke anstoßen</string>
    <string name="devices_device_config_nudge_volume_description">Senken und dann erhöhe die Lautstärke um eine Stufe, auch wenn die gewünschte Lautstärke (laut System) bereits eingestellt ist.</string>
    <string name="devices_device_config_visible_adjustments_label">Sichtbare Anpassungen</string>
    <string name="devices_device_config_visible_adjustments_desc">Zeigt das Lautstärkefenster des Systems an, während diese App Anpassungen für dieses Gerät vornimmt.</string>
    <string name="devices_device_config_keep_awake_label">Wach bleiben</string>
    <string name="devices_device_config_keep_awake_desc">Versuchen, das Gerät wach zu halten, während es verbunden ist. Das Verhalten kann je nach Android-Version variieren.</string>
    <string name="devices_device_config_volume_observe_label">Änderungen beobachten</string>
    <string name="devices_device_config_volume_observe_desc">Aktiv bleiben, während dieses Gerät verbunden ist und Lautstärkeänderungen speichern, die nicht von dieser App verursacht wurden.</string>
    <string name="devices_device_config_volume_save_on_disconnect_label">Lautstärke beim Trennen speichern</string>
    <string name="devices_device_config_volume_save_on_disconnect_desc">Aktuelle Lautstärkepegel erfassen und speichern, wenn dieses Gerät getrennt wird.</string>
    <string name="devices_device_config_volume_save_on_disconnect_hint">Auf manchen Geräten wechselt das System das Audio-Routing, bevor wir die Lautstärken auslesen können. Falls die gespeicherten Werte nicht mit deinen Einstellungen übereinstimmen, versuche stattdessen „Lautstärkeänderungen beobachten“ zu aktivieren.</string>
    <string name="devices_device_config_volume_lock_label">Lautstärkesperre</string>
    <string name="devices_device_config_volume_lock_desc">Alle nicht über diese App vorgenommenen Lautstärkeänderungen werden zurückgesetzt, während dieses Gerät verbunden ist.</string>
    <string name="devices_device_config_volume_lock_override_desc">Lautstärkesperre überschreibt diese Funktion derzeit.</string>
    <string name="devices_device_config_volume_rate_limiter_label">Lautstärke-Begrenzer</string>
    <string name="devices_device_config_volume_rate_limiter_desc">Begrenzt die Häufigkeit von Lautstärkeänderungen, um schnelle oder übermäßige Lautstärke-Anpassungen zu verhindern.</string>
