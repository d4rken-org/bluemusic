    <string name="onboarding_welcome_title">Willkommen bei BVM</string>
    <string name="onboarding_welcome_message">Bluetooth Volume Manager ermöglicht es Dir, Bluetooth-Gerätelautstärken automatisch zu verwalten.</string>
