    <string name="devices_device_config_monitoring_duration_desc">Zeit in Millisekunden nach durchgeführten Korrekturen, während der weitere Lautstärkeänderungen blockiert werden.</string>
    <string name="devices_device_config_adjustment_delay_label">Anpassungsverzögerung</string>
    <string name="devices_device_config_adjustment_delay_desc">Die Verzögerung der Anpassungsschritte in Millisekunden. Eine Verzögerung von 0 heißt, dass die gewünschte Lautstärke sofort beim Verbinden gesetzt wird.</string>
    <string name="devices_device_config_reaction_delay_label">Reaktionsverzögerung</string>
    <string name="devices_device_config_reaction_delay_desc">Die Verzögerung in Millisekunden bis diese App auf dieses Gerät reagiert.</string>
    <string name="devices_device_config_section_reaction_label">Reaktion</string>
    <string name="devices_device_config_launch_app_label">Apps starten</string>
